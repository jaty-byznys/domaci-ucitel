        {"id": "AJ4-05-01-015", "type": "choice", "question": "Co znamená 'shorts'?", "options": ["kalhoty", "kraťasy", "sukně", "plavky", "legíny"], "answer": "kraťasy", "hint": "Krátké kalhoty na léto."},
        {"id": "AJ4-05-01-016", "type": "choice", "question": "Co znamená 'pyjamas'?", "options": ["tepláky", "pyžamo", "domácí šaty", "župan", "mikina"], "answer": "pyžamo", "hint": "Oblečení na spaní."},
