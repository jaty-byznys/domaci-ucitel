{
  "id": "AJ4-06",
  "name": "Části těla",
  "order": 5,
  "prerequisite": null,
  "skills": [
    {
      "id": "AJ4-06-01",
      "name": "Části těla — anglicky → česky",
      "difficulty": 1,
      "theory": "Části těla: head = hlava, eye = oko, ear = ucho, nose = nos, mouth = ústa, hand = ruka (dlaň), arm = paže, leg = noha, foot = chodidlo/noha, hair = vlasy, tooth = zub, finger = prst (na ruce), toe = prst (na noze), knee = koleno, shoulder = rameno, neck = krk, back = záda, stomach/tummy = břicho, face = obličej, tongue = jazyk.",
      "tasks": [
        {"id": "AJ4-06-01-001", "type": "choice", "question": "Co znamená 'head'?", "options": ["ruka", "hlava", "noha", "krk", "rameno"], "answer": "hlava", "hint": "Úplně nahoře na těle."},
        {"id": "AJ4-06-01-002", "type": "choice", "question": "Co znamená 'eye'?", "options": ["ucho", "nos", "oko", "ústa", "obličej"], "answer": "oko", "hint": "Díváme se jím."},
        {"id": "AJ4-06-01-003", "type": "choice", "question": "Co znamená 'ear'?", "options": ["oko", "ucho", "nos", "ústa", "vlasy"], "answer": "ucho", "hint": "Slyšíme jím."},
        {"id": "AJ4-06-01-004", "type": "choice", "question": "Co znamená 'nose'?", "options": ["ústa", "oko", "ucho", "nos", "krk"], "answer": "nos", "hint": "Čicháme jím."},
        {"id": "AJ4-06-01-005", "type": "choice", "question": "Co znamená 'mouth'?", "options": ["nos", "oko", "ústa", "ucho", "jazyk"], "answer": "ústa", "hint": "Jíme a mluvíme jimi."},
        {"id": "AJ4-06-01-006", "type": "choice", "question": "Co znamená 'hand'?", "options": ["noha", "ruka", "paže", "prst", "rameno"], "answer": "ruka", "hint": "Máme na ní prsty, chytáme jí věci."},
        {"id": "AJ4-06-01-007", "type": "choice", "question": "Co znamená 'arm'?", "options": ["noha", "ruka", "paže", "rameno", "záda"], "answer": "paže", "hint": "Od ramene k ruce."},
        {"id": "AJ4-06-01-008", "type": "choice", "question": "Co znamená 'leg'?", "options": ["ruka", "paže", "noha", "koleno", "chodidlo"], "answer": "noha", "hint": "Chodíme po nich."},
        {"id": "AJ4-06-01-009", "type": "choice", "question": "Co znamená 'foot'?", "options": ["noha/chodidlo", "koleno", "prst", "kotník", "lýtko"], "answer": "noha/chodidlo", "hint": "Spodní část nohy, stojíme na něm."},
        {"id": "AJ4-06-01-010", "type": "choice", "question": "Co znamená 'hair'?", "options": ["ucho", "obličej", "vlasy", "čelo", "krk"], "answer": "vlasy", "hint": "Rostou na hlavě, češeme je."},
        {"id": "AJ4-06-01-011", "type": "choice", "question": "Co znamená 'tooth'?", "options": ["jazyk", "ret", "zub", "dáseň", "brada"], "answer": "zub", "hint": "Koušeme jím jídlo."},
        {"id": "AJ4-06-01-012", "type": "choice", "question": "Co znamená 'finger'?", "options": ["ruka", "paže", "prst na ruce", "prst na noze", "nehet"], "answer": "prst na ruce", "hint": "Máme jich 10 na rukou."},
        {"id": "AJ4-06-01-013", "type": "choice", "question": "Co znamená 'knee'?", "options": ["kotník", "loket", "koleno", "rameno", "bok"], "answer": "koleno", "hint": "Ohýbáme jím nohu."},
        {"id": "AJ4-06-01-014", "type": "choice", "question": "Co znamená 'shoulder'?", "options": ["koleno", "loket", "rameno", "krk", "záda"], "answer": "rameno", "hint": "Na něm nosíme batoh."},
        {"id": "AJ4-06-01-015", "type": "choice", "question": "Co znamená 'neck'?", "options": ["záda", "rameno", "krk", "brada", "hrudník"], "answer": "krk", "hint": "Spojuje hlavu a tělo."},
        {"id": "AJ4-06-01-016", "type": "choice", "question": "Co znamená 'back'?", "options": ["břicho", "hrudník", "záda", "rameno", "bok"], "answer": "záda", "hint": "Zadní strana těla."},
        {"id": "AJ4-06-01-017", "type": "choice", "question": "Co znamená 'stomach'?", "options": ["záda", "hrudník", "břicho", "bok", "krk"], "answer": "břicho", "hint": "Tam se tráví jídlo."},
        {"id": "AJ4-06-01-018", "type": "choice", "question": "Co znamená 'face'?", "options": ["hlava", "vlasy", "obličej", "krk", "čelo"], "answer": "obličej", "hint": "Oči, nos, ústa — to je face."},
        {"id": "AJ4-06-01-019", "type": "choice", "question": "Co znamená 'tongue'?", "options": ["zub", "ret", "jazyk", "dáseň", "brada"], "answer": "jazyk", "hint": "Ochutnáváme jím jídlo."},
        {"id": "AJ4-06-01-020", "type": "choice", "question": "Co znamená 'toe'?", "options": ["prst na ruce", "prst na noze", "nehet", "koleno", "kotník"], "answer": "prst na noze", "hint": "Jako finger, ale na noze."}
      ]
    },
    {
      "id": "AJ4-06-02",
      "name": "Části těla — česky → anglicky",
      "difficulty": 1,
      "theory": "Přeložíme části těla z češtiny do angličtiny!",
      "tasks": [
        {"id": "AJ4-06-02-001", "type": "choice", "question": "Jak se řekne anglicky 'hlava'?", "options": ["hand", "hair", "head", "hat", "heart"], "answer": "head", "hint": "Začíná na HE."},
        {"id": "AJ4-06-02-002", "type": "choice", "question": "Jak se řekne anglicky 'oko'?", "options": ["ear", "eye", "nose", "arm", "ice"], "answer": "eye", "hint": "Tři písmenka, začíná na E."},
        {"id": "AJ4-06-02-003", "type": "choice", "question": "Jak se řekne anglicky 'ucho'?", "options": ["eye", "arm", "ear", "egg", "eat"], "answer": "ear", "hint": "Tři písmenka, začíná na E."},
        {"id": "AJ4-06-02-004", "type": "choice", "question": "Jak se řekne anglicky 'nos'?", "options": ["neck", "nose", "knee", "nail", "name"], "answer": "nose", "hint": "Začíná na N, 4 písmenka."},
        {"id": "AJ4-06-02-005", "type": "choice", "question": "Jak se řekne anglicky 'ústa'?", "options": ["mouse", "mouth", "moustache", "muscle", "much"], "answer": "mouth", "hint": "Pozor — neplést s mouse (myš)!"},
        {"id": "AJ4-06-02-006", "type": "choice", "question": "Jak se řekne anglicky 'ruka'?", "options": ["arm", "hand", "head", "hair", "heart"], "answer": "hand", "hint": "Dlaň s prsty."},
        {"id": "AJ4-06-02-007", "type": "choice", "question": "Jak se řekne anglicky 'noha'?", "options": ["arm", "hand", "lip", "leg", "lung"], "answer": "leg", "hint": "Tři písmenka, začíná na L."},
        {"id": "AJ4-06-02-008", "type": "choice", "question": "Jak se řekne anglicky 'vlasy'?", "options": ["head", "hand", "hair", "hat", "hear"], "answer": "hair", "hint": "Začíná na HA, 4 písmenka."},
        {"id": "AJ4-06-02-009", "type": "choice", "question": "Jak se řekne anglicky 'zub'?", "options": ["tongue", "toe", "tooth", "top", "ten"], "answer": "tooth", "hint": "Začíná na T, 5 písmen."},
        {"id": "AJ4-06-02-010", "type": "choice", "question": "Jak se řekne anglicky 'prst na ruce'?", "options": ["toe", "thumb", "finger", "fist", "foot"], "answer": "finger", "hint": "Začíná na F."},
        {"id": "AJ4-06-02-011", "type": "choice", "question": "Jak se řekne anglicky 'koleno'?", "options": ["elbow", "ankle", "knee", "neck", "nail"], "answer": "knee", "hint": "Začíná na KN — K se nečte!"},
        {"id": "AJ4-06-02-012", "type": "choice", "question": "Jak se řekne anglicky 'krk'?", "options": ["knee", "nail", "neck", "nose", "net"], "answer": "neck", "hint": "Začíná na NE, 4 písmenka."},
        {"id": "AJ4-06-02-013", "type": "choice", "question": "Jak se řekne anglicky 'záda'?", "options": ["belly", "body", "bone", "back", "brain"], "answer": "back", "hint": "Začíná na B, 4 písmenka."},
        {"id": "AJ4-06-02-014", "type": "choice", "question": "Jak se řekne anglicky 'obličej'?", "options": ["head", "hair", "face", "front", "forehead"], "answer": "face", "hint": "Začíná na F, 4 písmenka."},
        {"id": "AJ4-06-02-015", "type": "choice", "question": "Jak se řekne anglicky 'rameno'?", "options": ["stomach", "shoulder", "shin", "side", "skull"], "answer": "shoulder", "hint": "Začíná na SH."}
      ]
    },
    {
      "id": "AJ4-06-03",
      "name": "Množné číslo — nepravidelné",
      "difficulty": 2,
      "theory": "Pozor na nepravidelné množné číslo! tooth → teeth (zuby), foot → feet (chodidla), eye → eyes, ear → ears. Ale: hair je nepočitatelné (vlasy).",
      "tasks": [
        {"id": "AJ4-06-03-001", "type": "choice", "question": "Jaké je množné číslo od 'tooth'?", "options": ["tooths", "toothes", "teeth", "teeths", "toothies"], "answer": "teeth", "hint": "Nepravidelné: tooth → teeth."},
        {"id": "AJ4-06-03-002", "type": "choice", "question": "Jaké je množné číslo od 'foot'?", "options": ["foots", "feets", "feet", "footes", "footies"], "answer": "feet", "hint": "Nepravidelné: foot → feet."},
        {"id": "AJ4-06-03-003", "type": "choice", "question": "Jaké je množné číslo od 'eye'?", "options": ["eyes", "eyen", "eyse", "eye", "eyees"], "answer": "eyes", "hint": "Pravidelné: eye → eyes."},
        {"id": "AJ4-06-03-004", "type": "choice", "question": "Jaké je množné číslo od 'hand'?", "options": ["handen", "hands", "handies", "hand", "handses"], "answer": "hands", "hint": "Pravidelné: hand → hands."},
        {"id": "AJ4-06-03-005", "type": "choice", "question": "Kolik 'eyes' máme?", "options": ["one", "two", "three", "four", "ten"], "answer": "two", "hint": "Dvě oči."},
        {"id": "AJ4-06-03-006", "type": "choice", "question": "Kolik 'fingers' máme celkem?", "options": ["five", "eight", "ten", "twelve", "twenty"], "answer": "ten", "hint": "5 na každé ruce."},
        {"id": "AJ4-06-03-007", "type": "choice", "question": "Kolik 'ears' máme?", "options": ["one", "two", "three", "four", "six"], "answer": "two", "hint": "Jedno na každé straně hlavy."},
        {"id": "AJ4-06-03-008", "type": "choice", "question": "Kolik 'noses' máme?", "options": ["one", "two", "three", "four", "zero"], "answer": "one", "hint": "Jen jeden nos."},
        {"id": "AJ4-06-03-009", "type": "choice", "question": "Co znamená 'teeth'?", "options": ["zub", "zuby", "dásně", "jazyk", "rty"], "answer": "zuby", "hint": "Tooth → teeth = množné číslo."},
        {"id": "AJ4-06-03-010", "type": "choice", "question": "Co znamená 'feet'?", "options": ["noha", "chodidla/nohy", "prsty", "kolena", "kotníky"], "answer": "chodidla/nohy", "hint": "Foot → feet = množné číslo."}
      ]
    },
    {
      "id": "AJ4-06-04",
      "name": "Co mě bolí — smysly",
      "difficulty": 2,
      "theory": "Bolí mě: I've got a headache = bolí mě hlava. I've got a stomachache = bolí mě břicho. My leg hurts = bolí mě noha. Smysly: eyes → see (vidět), ears → hear (slyšet), nose → smell (cítit/čichat), tongue → taste (chutnat), hands → touch (dotýkat se).",
      "tasks": [
        {"id": "AJ4-06-04-001", "type": "choice", "question": "Co znamená 'I've got a headache'?", "options": ["Bolí mě břicho.", "Bolí mě hlava.", "Bolí mě noha.", "Bolí mě zub.", "Bolí mě krk."], "answer": "Bolí mě hlava.", "hint": "Head + ache = bolest hlavy."},
        {"id": "AJ4-06-04-002", "type": "choice", "question": "Co znamená 'I've got a stomachache'?", "options": ["Bolí mě hlava.", "Bolí mě záda.", "Bolí mě břicho.", "Bolí mě ruka.", "Bolí mě ucho."], "answer": "Bolí mě břicho.", "hint": "Stomach + ache = bolest břicha."},
        {"id": "AJ4-06-04-003", "type": "choice", "question": "Co znamená 'I've got a toothache'?", "options": ["Bolí mě hlava.", "Bolí mě zub.", "Bolí mě jazyk.", "Bolí mě ústa.", "Bolí mě krk."], "answer": "Bolí mě zub.", "hint": "Tooth + ache = bolest zubu."},
        {"id": "AJ4-06-04-004", "type": "choice", "question": "Jak řekneš 'Bolí mě noha'?", "options": ["My arm hurts.", "My head hurts.", "My leg hurts.", "My back hurts.", "My hand hurts."], "answer": "My leg hurts.", "hint": "Leg = noha, hurts = bolí."},
        {"id": "AJ4-06-04-005", "type": "choice", "question": "Čím vidíme? We see with our ___.", "options": ["ears", "nose", "mouth", "eyes", "hands"], "answer": "eyes", "hint": "Oči slouží k vidění."},
        {"id": "AJ4-06-04-006", "type": "choice", "question": "Čím slyšíme? We hear with our ___.", "options": ["eyes", "ears", "nose", "mouth", "hands"], "answer": "ears", "hint": "Uši slouží ke slyšení."},
        {"id": "AJ4-06-04-007", "type": "choice", "question": "Čím čicháme? We smell with our ___.", "options": ["mouth", "ears", "eyes", "nose", "hands"], "answer": "nose", "hint": "Nos slouží k čichání."},
        {"id": "AJ4-06-04-008", "type": "choice", "question": "Čím ochutnáváme? We taste with our ___.", "options": ["nose", "ears", "eyes", "hands", "tongue"], "answer": "tongue", "hint": "Jazyk má chuťové pohárky."},
        {"id": "AJ4-06-04-009", "type": "choice", "question": "Čím se dotýkáme? We touch with our ___.", "options": ["eyes", "ears", "nose", "mouth", "hands"], "answer": "hands", "hint": "Rukama hmatáme."},
        {"id": "AJ4-06-04-010", "type": "choice", "question": "Co znamená 'My ear hurts'?", "options": ["Bolí mě oko.", "Bolí mě ucho.", "Bolí mě nos.", "Bolí mě krk.", "Bolí mě hlava."], "answer": "Bolí mě ucho.", "hint": "Ear = ucho, hurts = bolí."},
        {"id": "AJ4-06-04-011", "type": "choice", "question": "Co znamená 'I've got a sore throat'?", "options": ["Bolí mě hlava.", "Bolí mě krk.", "Bolí mě v krku.", "Bolí mě záda.", "Bolí mě ucho."], "answer": "Bolí mě v krku.", "hint": "Sore throat = bolest v krku."},
        {"id": "AJ4-06-04-012", "type": "choice", "question": "Co znamená 'I feel sick'?", "options": ["Jsem unavený.", "Je mi špatně.", "Jsem zdravý.", "Mám hlad.", "Jsem šťastný."], "answer": "Je mi špatně.", "hint": "Sick = nemocný/špatně."}
      ]
    },
    {
      "id": "AJ4-06-05",
      "name": "Popis osoby",
      "difficulty": 2,
      "theory": "Popíšeme osobu: She has got long hair. He has got blue eyes. She is tall. He is short. I have got brown hair and green eyes.",
      "tasks": [
        {"id": "AJ4-06-05-001", "type": "choice", "question": "Co znamená 'She has got long hair'?", "options": ["Má krátké vlasy.", "Má dlouhé vlasy.", "Má blond vlasy.", "Má kudrnaté vlasy.", "Nemá vlasy."], "answer": "Má dlouhé vlasy.", "hint": "Long = dlouhý."},
        {"id": "AJ4-06-05-002", "type": "choice", "question": "Co znamená 'He has got blue eyes'?", "options": ["Má zelené oči.", "Má hnědé oči.", "Má modré oči.", "Má šedé oči.", "Má černé oči."], "answer": "Má modré oči.", "hint": "Blue = modrý."},
        {"id": "AJ4-06-05-003", "type": "choice", "question": "Jak řekneš 'Má hnědé vlasy'?", "options": ["She has got brown eyes.", "She has got brown hair.", "She has got black hair.", "She has got blond hair.", "She has brown legs."], "answer": "She has got brown hair.", "hint": "Brown = hnědý, hair = vlasy."},
        {"id": "AJ4-06-05-004", "type": "choice", "question": "Co znamená 'tall'?", "options": ["malý", "tlustý", "hubený", "vysoký", "starý"], "answer": "vysoký", "hint": "Opak short (malý/nízký)."},
        {"id": "AJ4-06-05-005", "type": "choice", "question": "Co znamená 'short' (u osoby)?", "options": ["vysoký", "malý/nízký", "tlustý", "hubený", "mladý"], "answer": "malý/nízký", "hint": "Opak tall."},
        {"id": "AJ4-06-05-006", "type": "choice", "question": "Co znamená 'curly hair'?", "options": ["rovné vlasy", "krátké vlasy", "kudrnaté vlasy", "dlouhé vlasy", "blond vlasy"], "answer": "kudrnaté vlasy", "hint": "Curly = kudrnatý."},
        {"id": "AJ4-06-05-007", "type": "choice", "question": "Co znamená 'straight hair'?", "options": ["kudrnaté vlasy", "vlnité vlasy", "rovné vlasy", "krátké vlasy", "zrzavé vlasy"], "answer": "rovné vlasy", "hint": "Straight = rovný."},
        {"id": "AJ4-06-05-008", "type": "choice", "question": "Jak řekneš 'Jsem vysoký'?", "options": ["I am short.", "I am small.", "I am tall.", "I am big.", "I am long."], "answer": "I am tall.", "hint": "Tall = vysoký (o osobě)."},
        {"id": "AJ4-06-05-009", "type": "choice", "question": "Co znamená 'blond hair'?", "options": ["černé vlasy", "hnědé vlasy", "světlé/plavé vlasy", "zrzavé vlasy", "šedé vlasy"], "answer": "světlé/plavé vlasy", "hint": "Blond = světlý (vlasy)."},
        {"id": "AJ4-06-05-010", "type": "choice", "question": "Co znamená 'He is wearing glasses'?", "options": ["Nosí čepici.", "Nosí rukavice.", "Nosí brýle.", "Nosí hodinky.", "Nosí náušnice."], "answer": "Nosí brýle.", "hint": "Glasses = brýle."},
        {"id": "AJ4-06-05-011", "type": "choice", "question": "Jak řekneš 'Má zelené oči a krátké vlasy'?", "options": ["He has got green hair and short eyes.", "He has got green eyes and short hair.", "He has got blue eyes and long hair.", "He has got brown eyes and short hair.", "He has got green ears and short hair."], "answer": "He has got green eyes and short hair.", "hint": "Green eyes = zelené oči, short hair = krátké vlasy."},
        {"id": "AJ4-06-05-012", "type": "choice", "question": "Co znamená 'freckles'?", "options": ["vrásky", "pihy", "jizvy", "pupínky", "mateřská znaménka"], "answer": "pihy", "hint": "Malé hnědé tečky na obličeji."},
        {"id": "AJ4-06-05-013", "type": "choice", "question": "Co znamená 'smile'?", "options": ["mračit se", "křičet", "usmívat se", "plakat", "šeptat"], "answer": "usmívat se", "hint": "Když jsme šťastní, děláme to."}
      ]
    },
    {
      "id": "AJ4-06-06",
      "name": "Části těla — mix",
      "difficulty": 2,
      "theory": "Všechno dohromady!",
      "tasks": [
        {"id": "AJ4-06-06-001", "type": "choice", "question": "Které slovo NEPATŘÍ mezi části těla?", "options": ["hand", "leg", "chair", "nose", "ear"], "answer": "chair", "hint": "Chair = židle."},
        {"id": "AJ4-06-06-002", "type": "choice", "question": "Co je na obličeji (face)?", "options": ["knee and elbow", "eyes, nose, mouth", "shoulder and back", "hand and finger", "leg and foot"], "answer": "eyes, nose, mouth", "hint": "Oči, nos, ústa jsou na obličeji."},
        {"id": "AJ4-06-06-003", "type": "choice", "question": "Která dvojice je SPRÁVNÁ?", "options": ["eye — ucho", "ear — oko", "nose — nos", "mouth — nos", "hand — noha"], "answer": "nose — nos", "hint": "Eye = oko, ear = ucho, mouth = ústa, hand = ruka."},
        {"id": "AJ4-06-06-004", "type": "choice", "question": "Co znamená 'elbow'?", "options": ["koleno", "loket", "kotník", "rameno", "zápěstí"], "answer": "loket", "hint": "Ohýbáme jím paži."},
        {"id": "AJ4-06-06-005", "type": "choice", "question": "Co znamená 'ankle'?", "options": ["koleno", "loket", "kotník", "zápěstí", "bok"], "answer": "kotník", "hint": "Kloub mezi nohou a chodidlem."},
        {"id": "AJ4-06-06-006", "type": "choice", "question": "Co znamená 'thumb'?", "options": ["malíček", "ukazovák", "palec", "prostředníček", "prsteníček"], "answer": "palec", "hint": "Nejsilnější prst na ruce."},
        {"id": "AJ4-06-06-007", "type": "choice", "question": "Co znamená 'Body' v angličtině?", "options": ["hlava", "obličej", "tělo", "záda", "kůže"], "answer": "tělo", "hint": "Celé tělo = body."},
        {"id": "AJ4-06-06-008", "type": "choice", "question": "Jak řekneš 'Zvedni ruce!'?", "options": ["Put your hands down!", "Clap your hands!", "Raise your hands!", "Wash your hands!", "Hold your hands!"], "answer": "Raise your hands!", "hint": "Raise = zvednout."},
