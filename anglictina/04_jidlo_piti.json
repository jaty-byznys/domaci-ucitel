{
  "id": "AJ4-04",
  "name": "Jídlo a pití",
  "order": 3,
  "prerequisite": null,
  "skills": [
    {
      "id": "AJ4-04-01",
      "name": "Jídlo — anglicky → česky",
      "difficulty": 1,
      "theory": "Základní jídla: bread = chléb, butter = máslo, cheese = sýr, egg = vejce, pizza = pizza, soup = polévka, meat = maso, rice = rýže, pasta = těstoviny, cake = dort, ice cream = zmrzlina, sandwich = sendvič, chips = hranolky, salad = salát, sausage = párek/klobása, ham = šunka, fish = ryba, chicken = kuře.",
      "tasks": [
        {"id": "AJ4-04-01-001", "type": "choice", "question": "Co znamená 'bread'?", "options": ["máslo", "chléb", "sýr", "dort", "rýže"], "answer": "chléb", "hint": "Pečivo, krájíme na krajíce."},
        {"id": "AJ4-04-01-002", "type": "choice", "question": "Co znamená 'butter'?", "options": ["chléb", "sýr", "máslo", "maso", "vejce"], "answer": "máslo", "hint": "Žluté, mažeme na chléb."},
        {"id": "AJ4-04-01-003", "type": "choice", "question": "Co znamená 'cheese'?", "options": ["máslo", "šunka", "dort", "sýr", "rýže"], "answer": "sýr", "hint": "Říkáme 'cheese' i při focení!"},
        {"id": "AJ4-04-01-004", "type": "choice", "question": "Co znamená 'egg'?", "options": ["maso", "vejce", "ryba", "párek", "chléb"], "answer": "vejce", "hint": "Slepice ho snese."},
        {"id": "AJ4-04-01-005", "type": "choice", "question": "Co znamená 'soup'?", "options": ["salát", "polévka", "omáčka", "kaše", "kompot"], "answer": "polévka", "hint": "Tekuté jídlo, jíme lžící."},
        {"id": "AJ4-04-01-006", "type": "choice", "question": "Co znamená 'meat'?", "options": ["mléko", "mouka", "maso", "med", "máslo"], "answer": "maso", "hint": "Hovězí, vepřové, kuřecí..."},
        {"id": "AJ4-04-01-007", "type": "choice", "question": "Co znamená 'rice'?", "options": ["rýže", "kukuřice", "mouka", "těstoviny", "brambory"], "answer": "rýže", "hint": "Bílá, malá zrnka, vaříme ve vodě."},
        {"id": "AJ4-04-01-008", "type": "choice", "question": "Co znamená 'pasta'?", "options": ["dort", "těstoviny", "pizza", "chléb", "kaše"], "answer": "těstoviny", "hint": "Špagety, penne, fusilli..."},
        {"id": "AJ4-04-01-009", "type": "choice", "question": "Co znamená 'cake'?", "options": ["koláč", "dort", "sušenka", "zmrzlina", "bonbon"], "answer": "dort", "hint": "Sladký, slavnostní, na narozeniny."},
        {"id": "AJ4-04-01-010", "type": "choice", "question": "Co znamená 'ice cream'?", "options": ["dort", "bonbon", "zmrzlina", "led", "jogurt"], "answer": "zmrzlina", "hint": "Ice = led, cream = krém. Studená sladkost."},
        {"id": "AJ4-04-01-011", "type": "choice", "question": "Co znamená 'sandwich'?", "options": ["salát", "sendvič", "párek", "pizza", "toast"], "answer": "sendvič", "hint": "Dva plátky chleba a něco mezi nimi."},
        {"id": "AJ4-04-01-012", "type": "choice", "question": "Co znamená 'chips'?", "options": ["sušenky", "bonbony", "hranolky", "chipsy", "křupky"], "answer": "hranolky", "hint": "V britské angličtině chips = hranolky!"},
        {"id": "AJ4-04-01-013", "type": "choice", "question": "Co znamená 'sausage'?", "options": ["šunka", "párek", "salám", "maso", "kuře"], "answer": "párek", "hint": "Dlouhý, válcovitý, grilujeme ho."},
        {"id": "AJ4-04-01-014", "type": "choice", "question": "Co znamená 'ham'?", "options": ["párek", "maso", "šunka", "sýr", "salám"], "answer": "šunka", "hint": "Růžová, krájená, do sendviče."},
        {"id": "AJ4-04-01-015", "type": "choice", "question": "Co znamená 'salad'?", "options": ["polévka", "omáčka", "salát", "kompot", "zelenina"], "answer": "salát", "hint": "Zelenina smíchaná dohromady."}
      ]
    },
    {
      "id": "AJ4-04-02",
      "name": "Ovoce a zelenina",
      "difficulty": 1,
      "theory": "Ovoce (fruit): apple = jablko, banana = banán, orange = pomeranč, strawberry = jahoda, grape = hrozen, pear = hruška, lemon = citron, cherry = třešeň. Zelenina (vegetables): tomato = rajče, potato = brambora, carrot = mrkev, onion = cibule, cucumber = okurka, pepper = paprika, pea = hrášek.",
      "tasks": [
        {"id": "AJ4-04-02-001", "type": "choice", "question": "Co znamená 'apple'?", "options": ["hruška", "jablko", "pomeranč", "banán", "jahoda"], "answer": "jablko", "hint": "Červené nebo zelené ovoce."},
        {"id": "AJ4-04-02-002", "type": "choice", "question": "Co znamená 'banana'?", "options": ["jablko", "pomeranč", "banán", "citron", "hruška"], "answer": "banán", "hint": "Žluté, zakřivené ovoce."},
        {"id": "AJ4-04-02-003", "type": "choice", "question": "Co znamená 'strawberry'?", "options": ["jahoda", "malina", "třešeň", "hrozen", "borůvka"], "answer": "jahoda", "hint": "Červená, sladká, roste na záhonku."},
        {"id": "AJ4-04-02-004", "type": "choice", "question": "Co znamená 'tomato'?", "options": ["brambora", "rajče", "paprika", "mrkev", "cibule"], "answer": "rajče", "hint": "Červené, kulaté, dáváme do salátu."},
        {"id": "AJ4-04-02-005", "type": "choice", "question": "Co znamená 'potato'?", "options": ["rajče", "mrkev", "brambora", "cibule", "paprika"], "answer": "brambora", "hint": "Roste pod zemí, děláme z ní hranolky."},
        {"id": "AJ4-04-02-006", "type": "choice", "question": "Co znamená 'carrot'?", "options": ["cibule", "brambora", "okurka", "mrkev", "hrášek"], "answer": "mrkev", "hint": "Oranžová, králíci ji milují."},
        {"id": "AJ4-04-02-007", "type": "choice", "question": "Co znamená 'onion'?", "options": ["mrkev", "cibule", "česnek", "brambora", "paprika"], "answer": "cibule", "hint": "Při krájení z ní slzíme."},
        {"id": "AJ4-04-02-008", "type": "choice", "question": "Jak se řekne anglicky 'jablko'?", "options": ["orange", "pear", "apple", "grape", "cherry"], "answer": "apple", "hint": "Začíná na A."},
        {"id": "AJ4-04-02-009", "type": "choice", "question": "Jak se řekne anglicky 'rajče'?", "options": ["potato", "tomato", "carrot", "pepper", "onion"], "answer": "tomato", "hint": "Začíná na T."},
        {"id": "AJ4-04-02-010", "type": "choice", "question": "Jak se řekne anglicky 'brambora'?", "options": ["tomato", "carrot", "onion", "potato", "pea"], "answer": "potato", "hint": "Začíná na P."},
        {"id": "AJ4-04-02-011", "type": "choice", "question": "Jak se řekne anglicky 'mrkev'?", "options": ["cucumber", "onion", "carrot", "potato", "pepper"], "answer": "carrot", "hint": "Začíná na C."},
        {"id": "AJ4-04-02-012", "type": "choice", "question": "Co znamená 'grape'?", "options": ["jahoda", "hruška", "třešeň", "hrozen", "citron"], "answer": "hrozen", "hint": "Roste na vinici, dělá se z něj víno."},
        {"id": "AJ4-04-02-013", "type": "choice", "question": "Co znamená 'lemon'?", "options": ["pomeranč", "citron", "banán", "hruška", "jablko"], "answer": "citron", "hint": "Žlutý a kyselý."},
        {"id": "AJ4-04-02-014", "type": "choice", "question": "Co znamená 'pear'?", "options": ["hrozen", "jahoda", "třešeň", "hruška", "jablko"], "answer": "hruška", "hint": "Podobná jablku, ale protáhlejší."},
        {"id": "AJ4-04-02-015", "type": "choice", "question": "Které slovo je OVOCE (fruit)?", "options": ["potato", "carrot", "onion", "cherry", "pepper"], "answer": "cherry", "hint": "Cherry = třešeň — to je ovoce."},
        {"id": "AJ4-04-02-016", "type": "choice", "question": "Které slovo je ZELENINA (vegetable)?", "options": ["apple", "banana", "cucumber", "strawberry", "grape"], "answer": "cucumber", "hint": "Cucumber = okurka — to je zelenina."}
      ]
    },
    {
      "id": "AJ4-04-03",
      "name": "Pití — drinks",
      "difficulty": 1,
      "theory": "Nápoje: water = voda, milk = mléko, juice = džus, tea = čaj, coffee = káva, lemonade = limonáda, hot chocolate = horká čokoláda.",
      "tasks": [
        {"id": "AJ4-04-03-001", "type": "choice", "question": "Co znamená 'water'?", "options": ["mléko", "voda", "džus", "čaj", "limonáda"], "answer": "voda", "hint": "Pijeme ji nejvíc ze všeho."},
        {"id": "AJ4-04-03-002", "type": "choice", "question": "Co znamená 'milk'?", "options": ["voda", "džus", "mléko", "káva", "čaj"], "answer": "mléko", "hint": "Bílé, dává ho kráva."},
        {"id": "AJ4-04-03-003", "type": "choice", "question": "Co znamená 'juice'?", "options": ["čaj", "káva", "voda", "džus", "mléko"], "answer": "džus", "hint": "Vymačkaný z ovoce."},
        {"id": "AJ4-04-03-004", "type": "choice", "question": "Co znamená 'tea'?", "options": ["káva", "čaj", "voda", "džus", "mléko"], "answer": "čaj", "hint": "Horký nápoj, louhujeme sáček."},
        {"id": "AJ4-04-03-005", "type": "choice", "question": "Jak se řekne anglicky 'voda'?", "options": ["milk", "juice", "tea", "water", "coffee"], "answer": "water", "hint": "Začíná na W."},
        {"id": "AJ4-04-03-006", "type": "choice", "question": "Jak se řekne anglicky 'mléko'?", "options": ["water", "milk", "juice", "tea", "lemonade"], "answer": "milk", "hint": "Začíná na M, 4 písmenka."},
        {"id": "AJ4-04-03-007", "type": "choice", "question": "Jak se řekne anglicky 'džus'?", "options": ["juice", "tea", "milk", "water", "coffee"], "answer": "juice", "hint": "Začíná na J."},
        {"id": "AJ4-04-03-008", "type": "choice", "question": "Co znamená 'hot chocolate'?", "options": ["horký čaj", "horká káva", "horká čokoláda", "horká voda", "horké mléko"], "answer": "horká čokoláda", "hint": "Hot = horký, chocolate = čokoláda."},
        {"id": "AJ4-04-03-009", "type": "choice", "question": "Které slovo je NÁPOJ?", "options": ["bread", "cheese", "lemonade", "cake", "rice"], "answer": "lemonade", "hint": "Lemonade = limonáda — to se pije."},
        {"id": "AJ4-04-03-010", "type": "choice", "question": "Co znamená 'orange juice'?", "options": ["oranžový dort", "pomerančový džus", "citronová šťáva", "jablečný mošt", "oranžové mléko"], "answer": "pomerančový džus", "hint": "Orange = pomeranč, juice = džus."}
      ]
    },
    {
      "id": "AJ4-04-04",
      "name": "I like / I don't like",
      "difficulty": 2,
      "theory": "Řekneme co máme rádi: I like pizza. I love ice cream. I don't like soup. I hate onions. Do you like cheese? Yes, I do. / No, I don't.",
      "tasks": [
        {"id": "AJ4-04-04-001", "type": "choice", "question": "Jak řekneš 'Mám rád pizzu'?", "options": ["I am pizza.", "I have pizza.", "I like pizza.", "I want pizza.", "I eat pizza."], "answer": "I like pizza.", "hint": "Like = mít rád."},
        {"id": "AJ4-04-04-002", "type": "choice", "question": "Jak řekneš 'Nemám rád polévku'?", "options": ["I not like soup.", "I don't like soup.", "I am not soup.", "I doesn't like soup.", "I no like soup."], "answer": "I don't like soup.", "hint": "Nemám rád = I don't like."},
        {"id": "AJ4-04-04-003", "type": "choice", "question": "Co znamená 'She likes bananas'?", "options": ["Ona má banány.", "Ona jí banány.", "Ona má ráda banány.", "Ona chce banány.", "Ona kupuje banány."], "answer": "Ona má ráda banány.", "hint": "Likes = má rád/ráda (3. osoba)."},
        {"id": "AJ4-04-04-004", "type": "choice", "question": "Co znamená 'He doesn't like fish'?", "options": ["On nemá rybu.", "On nejí rybu.", "On nemá rád rybu.", "On nechce rybu.", "On nevidí rybu."], "answer": "On nemá rád rybu.", "hint": "Doesn't like = nemá rád."},
        {"id": "AJ4-04-04-005", "type": "choice", "question": "Doplň: '___ you like cheese?' — 'Yes, I ___.'", "options": ["Are / am", "Do / do", "Is / is", "Have / have", "Does / does"], "answer": "Do / do", "hint": "Do you like? → Yes, I do."},
        {"id": "AJ4-04-04-006", "type": "choice", "question": "Doplň: '___ she like pasta?' — 'No, she ___.'", "options": ["Do / don't", "Does / doesn't", "Is / isn't", "Has / hasn't", "Are / aren't"], "answer": "Does / doesn't", "hint": "She → does. Zápor → doesn't."},
        {"id": "AJ4-04-04-007", "type": "choice", "question": "Co znamená 'I love chocolate'?", "options": ["Mám rád čokoládu.", "Miluju čokoládu.", "Chci čokoládu.", "Jím čokoládu.", "Mám čokoládu."], "answer": "Miluju čokoládu.", "hint": "Love = milovat (silnější než like)."},
        {"id": "AJ4-04-04-008", "type": "choice", "question": "Co znamená 'I hate onions'?", "options": ["Mám rád cibuli.", "Jím cibuli.", "Nesnáším cibuli.", "Nemám cibuli.", "Chci cibuli."], "answer": "Nesnáším cibuli.", "hint": "Hate = nesnášet (silnější než don't like)."},
        {"id": "AJ4-04-04-009", "type": "choice", "question": "Jak řekneš 'Máš rád zmrzlinu?'", "options": ["Are you ice cream?", "Have you ice cream?", "Do you like ice cream?", "Is you like ice cream?", "You like ice cream?"], "answer": "Do you like ice cream?", "hint": "Do you like + jídlo?"},
        {"id": "AJ4-04-04-010", "type": "choice", "question": "Co znamená 'My favourite food is pizza'?", "options": ["Moje jídlo je pizza.", "Mám rád pizzu.", "Moje oblíbené jídlo je pizza.", "Pizza je jídlo.", "Jím pizzu."], "answer": "Moje oblíbené jídlo je pizza.", "hint": "Favourite = oblíbený."},
        {"id": "AJ4-04-04-011", "type": "choice", "question": "Jak řekneš 'Můj bratr nemá rád sýr'?", "options": ["My brother don't like cheese.", "My brother doesn't like cheese.", "My brother not like cheese.", "My brother isn't like cheese.", "My brother no like cheese."], "answer": "My brother doesn't like cheese.", "hint": "My brother = he → doesn't."},
        {"id": "AJ4-04-04-012", "type": "choice", "question": "Co znamená 'What is your favourite drink?'", "options": ["Co piješ?", "Máš pití?", "Jaký je tvůj oblíbený nápoj?", "Chceš pít?", "Kde je tvůj nápoj?"], "answer": "Jaký je tvůj oblíbený nápoj?", "hint": "Favourite drink = oblíbený nápoj."}
      ]
    },
    {
      "id": "AJ4-04-05",
      "name": "Jídlo — věty a situace",
      "difficulty": 2,
      "theory": "V restauraci nebo obchodě: Can I have...? I would like... Here you are. How much is it? I'm hungry. I'm thirsty.",
      "tasks": [
        {"id": "AJ4-04-05-001", "type": "choice", "question": "Co znamená 'I'm hungry'?", "options": ["Jsem unavený.", "Mám žízeň.", "Mám hlad.", "Je mi zima.", "Mám radost."], "answer": "Mám hlad.", "hint": "Hungry = hladový."},
        {"id": "AJ4-04-05-002", "type": "choice", "question": "Co znamená 'I'm thirsty'?", "options": ["Mám hlad.", "Mám žízeň.", "Je mi horko.", "Jsem nemocný.", "Jsem unavený."], "answer": "Mám žízeň.", "hint": "Thirsty = žíznivý."},
        {"id": "AJ4-04-05-003", "type": "choice", "question": "Jak řekneš 'Mohu dostat vodu?'", "options": ["I am water.", "Give me water.", "Can I have water, please?", "I want water now.", "Where is water?"], "answer": "Can I have water, please?", "hint": "Can I have = mohu dostat."},
        {"id": "AJ4-04-05-004", "type": "choice", "question": "Co znamená 'Here you are'?", "options": ["Kde jsi?", "Tady jsi.", "Tady máš / Prosím.", "Pojď sem.", "Jsi tady."], "answer": "Tady máš / Prosím.", "hint": "Říkáme, když někomu něco podáváme."},
        {"id": "AJ4-04-05-005", "type": "choice", "question": "Co znamená 'How much is it?'?", "options": ["Kolik je hodin?", "Kolik to stojí?", "Kolik toho je?", "Jak je to daleko?", "Kolik máš?"], "answer": "Kolik to stojí?", "hint": "How much = kolik (cena)."},
        {"id": "AJ4-04-05-006", "type": "choice", "question": "Jak řekneš 'Chtěl bych pizzu'?", "options": ["I like pizza.", "I am pizza.", "I would like a pizza.", "I have pizza.", "I need pizza."], "answer": "I would like a pizza.", "hint": "I would like = chtěl bych (zdvořile)."},
        {"id": "AJ4-04-05-007", "type": "choice", "question": "Co znamená 'breakfast'?", "options": ["oběd", "večeře", "snídaně", "svačina", "dezert"], "answer": "snídaně", "hint": "Ráno, po probuzení."},
        {"id": "AJ4-04-05-008", "type": "choice", "question": "Co znamená 'lunch'?", "options": ["snídaně", "oběd", "večeře", "svačina", "dezert"], "answer": "oběd", "hint": "Kolem poledne."},
        {"id": "AJ4-04-05-009", "type": "choice", "question": "Co znamená 'dinner'?", "options": ["snídaně", "oběd", "večeře", "svačina", "dezert"], "answer": "večeře", "hint": "Večer, poslední jídlo dne."},
        {"id": "AJ4-04-05-010", "type": "choice", "question": "Jak se řekne anglicky 'snídaně'?", "options": ["lunch", "dinner", "supper", "breakfast", "brunch"], "answer": "breakfast", "hint": "Break + fast = přerušit půst (po noci)."},
        {"id": "AJ4-04-05-011", "type": "choice", "question": "Co znamená 'I have bread and butter for breakfast'?", "options": ["Na oběd mám chléb a máslo.", "Na snídani mám chléb a sýr.", "Na snídani mám chléb a máslo.", "Na večeři mám chléb a máslo.", "Na svačinu mám chléb a máslo."], "answer": "Na snídani mám chléb a máslo.", "hint": "Breakfast = snídaně, bread = chléb, butter = máslo."},
        {"id": "AJ4-04-05-012", "type": "choice", "question": "Co znamená 'delicious'?", "options": ["ošklivý", "studený", "výborný/lahodný", "velký", "malý"], "answer": "výborný/lahodný", "hint": "Když jídlo chutná skvěle."}
      ]
    },
    {
      "id": "AJ4-04-06",
      "name": "Jídlo a pití — mix",
      "difficulty": 2,
      "theory": "Všechno dohromady — jídlo, pití, ovoce, zelenina, věty!",
      "tasks": [
        {"id": "AJ4-04-06-001", "type": "choice", "question": "Které slovo NEPATŘÍ mezi jídlo?", "options": ["bread", "cheese", "pencil", "cake", "rice"], "answer": "pencil", "hint": "Pencil = tužka."},
        {"id": "AJ4-04-06-002", "type": "choice", "question": "Které slovo NEPATŘÍ mezi nápoje?", "options": ["water", "juice", "milk", "chair", "tea"], "answer": "chair", "hint": "Chair = židle."},
        {"id": "AJ4-04-06-003", "type": "choice", "question": "Které slovo NEPATŘÍ mezi ovoce?", "options": ["apple", "banana", "potato", "strawberry", "pear"], "answer": "potato", "hint": "Potato = brambora — to je zelenina."},
        {"id": "AJ4-04-06-004", "type": "choice", "question": "Co znamená 'I eat an apple every day'?", "options": ["Jím jablka každý den.", "Mám rád jablka.", "Kupuji jablko každý den.", "Chci jablko každý den.", "Vidím jablko každý den."], "answer": "Jím jablka každý den.", "hint": "Eat = jíst, every day = každý den."},
        {"id": "AJ4-04-06-005", "type": "choice", "question": "Co znamená 'I drink milk every morning'?", "options": ["Piji mléko každé ráno.", "Mám rád mléko.", "Kupuji mléko ráno.", "Mléko je na ráno.", "Piji vodu každé ráno."], "answer": "Piji mléko každé ráno.", "hint": "Drink = pít, every morning = každé ráno."},
        {"id": "AJ4-04-06-006", "type": "choice", "question": "Doplň: 'I usually have ___ for breakfast.' (chléb)", "options": ["cheese", "rice", "bread", "pasta", "meat"], "answer": "bread", "hint": "Chléb = bread."},
        {"id": "AJ4-04-06-007", "type": "choice", "question": "Co znamená 'some'?", "options": ["žádný", "každý", "nějaký/trochu", "hodně", "málo"], "answer": "nějaký/trochu", "hint": "Can I have some water? = trochu vody."},
        {"id": "AJ4-04-06-008", "type": "choice", "question": "Co znamená 'There is some milk in the fridge'?", "options": ["Mléko je studené.", "V lednici je nějaké mléko.", "V lednici není mléko.", "Mléko je v obchodě.", "Kupuji mléko."], "answer": "V lednici je nějaké mléko.", "hint": "Fridge = lednice, some = nějaké."},
        {"id": "AJ4-04-06-009", "type": "choice", "question": "Jak řekneš 'Chci tři jablka'?", "options": ["I want three apple.", "I want three apples.", "I like three apples.", "I have three apple.", "Three apples I want."], "answer": "I want three apples.", "hint": "Three → množné číslo → apples."},
