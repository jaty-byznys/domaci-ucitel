      "theory": "Přeložíme školní potřeby do angličtiny!",
      "tasks": [
        {"id": "AJ4-07-02-001", "type": "choice", "question": "Jak se řekne anglicky 'kniha'?", "options": ["notebook", "book", "pencil case", "bag", "pen"], "answer": "book", "hint": "Začíná na B, 4 písmenka."},
        {"id": "AJ4-07-02-002", "type": "choice", "question": "Jak se řekne anglicky 'tužka'?", "options": ["pen", "pencil", "ruler", "rubber", "chalk"], "answer": "pencil", "hint": "Začíná na P, delší než 'pen'."},
        {"id": "AJ4-07-02-003", "type": "choice", "question": "Jak se řekne anglicky 'pero'?", "options": ["pencil", "pen", "pin", "pan", "peg"], "answer": "pen", "hint": "Tři písmenka, začíná na P."},
        {"id": "AJ4-07-02-004", "type": "choice", "question": "Jak se řekne anglicky 'guma'?", "options": ["ruler", "glue", "rubber", "scissors", "sharpener"], "answer": "rubber", "hint": "Nebo taky 'eraser'."},
        {"id": "AJ4-07-02-005", "type": "choice", "question": "Jak se řekne anglicky 'pravítko'?", "options": ["rubber", "ruler", "pencil", "pen", "sharpener"], "answer": "ruler", "hint": "Začíná na R, 5 písmen."},
        {"id": "AJ4-07-02-006", "type": "choice", "question": "Jak se řekne anglicky 'taška'?", "options": ["box", "bag", "bin", "bed", "bus"], "answer": "bag", "hint": "Tři písmenka, začíná na B."},
        {"id": "AJ4-07-02-007", "type": "choice", "question": "Jak se řekne anglicky 'tabule'?", "options": ["desk", "door", "board", "wall", "floor"], "answer": "board", "hint": "Začíná na B, 5 písmen."},
        {"id": "AJ4-07-02-008", "type": "choice", "question": "Jak se řekne anglicky 'sešit'?", "options": ["book", "notebook", "textbook", "diary", "folder"], "answer": "notebook", "hint": "Note = poznámka + book = kniha."},
        {"id": "AJ4-07-02-009", "type": "choice", "question": "Jak se řekne anglicky 'penál'?", "options": ["pencil box", "pencil case", "pen bag", "pen box", "pencil bag"], "answer": "pencil case", "hint": "Pencil + case."},
        {"id": "AJ4-07-02-010", "type": "choice", "question": "Jak se řekne anglicky 'nůžky'?", "options": ["sharpener", "stapler", "scissors", "glue", "tape"], "answer": "scissors", "hint": "Začíná na SC."},
        {"id": "AJ4-07-02-011", "type": "choice", "question": "Jak se řekne anglicky 'lepidlo'?", "options": ["tape", "scissors", "glue", "rubber", "paint"], "answer": "glue", "hint": "Začíná na G, 4 písmenka."},
        {"id": "AJ4-07-02-012", "type": "choice", "question": "Jak se řekne anglicky 'židle'?", "options": ["desk", "table", "chair", "shelf", "bench"], "answer": "chair", "hint": "Začíná na CH."}
      ]
    },
    {
      "id": "AJ4-07-03",
      "name": "Škola — místnosti a předměty",
      "difficulty": 2,
      "theory": "Místnosti ve škole: classroom = učebna, gym = tělocvična, library = knihovna, canteen = jídelna, playground = hřiště, corridor/hall = chodba. Předměty: maths = matematika, Czech = čeština, English = angličtina, science = přírodověda, PE = tělocvik, art = výtvarná výchova, music = hudební výchova.",
      "tasks": [
        {"id": "AJ4-07-03-001", "type": "choice", "question": "Co znamená 'gym'?", "options": ["jídelna", "knihovna", "tělocvična", "chodba", "třída"], "answer": "tělocvična", "hint": "Cvičíme tam."},
        {"id": "AJ4-07-03-002", "type": "choice", "question": "Co znamená 'library'?", "options": ["jídelna", "knihovna", "chodba", "hřiště", "učebna"], "answer": "knihovna", "hint": "Půjčujeme si tam knihy."},
        {"id": "AJ4-07-03-003", "type": "choice", "question": "Co znamená 'canteen'?", "options": ["třída", "tělocvična", "jídelna", "knihovna", "hřiště"], "answer": "jídelna", "hint": "Jíme tam oběd."},
        {"id": "AJ4-07-03-004", "type": "choice", "question": "Co znamená 'playground'?", "options": ["tělocvična", "chodba", "třída", "hřiště", "jídelna"], "answer": "hřiště", "hint": "Play = hrát si, ground = pozemek."},
        {"id": "AJ4-07-03-005", "type": "choice", "question": "Co znamená 'maths'?", "options": ["čeština", "angličtina", "matematika", "přírodověda", "tělocvik"], "answer": "matematika", "hint": "Počítáme tam."},
        {"id": "AJ4-07-03-006", "type": "choice", "question": "Co znamená 'PE'?", "options": ["matematika", "angličtina", "výtvarná výchova", "tělocvik", "hudební výchova"], "answer": "tělocvik", "hint": "PE = Physical Education = tělesná výchova."},
        {"id": "AJ4-07-03-007", "type": "choice", "question": "Co znamená 'art'?", "options": ["hudební výchova", "tělocvik", "výtvarná výchova", "matematika", "přírodověda"], "answer": "výtvarná výchova", "hint": "Kreslíme a malujeme."},
        {"id": "AJ4-07-03-008", "type": "choice", "question": "Co znamená 'music'?", "options": ["výtvarná výchova", "hudební výchova", "tělocvik", "čeština", "angličtina"], "answer": "hudební výchova", "hint": "Zpíváme a hrajeme na nástroje."},
        {"id": "AJ4-07-03-009", "type": "choice", "question": "Co znamená 'science'?", "options": ["matematika", "čeština", "přírodověda", "dějepis", "zeměpis"], "answer": "přírodověda", "hint": "Učíme se o přírodě a pokusech."},
        {"id": "AJ4-07-03-010", "type": "choice", "question": "Jak se řekne anglicky 'matematika'?", "options": ["music", "art", "PE", "maths", "science"], "answer": "maths", "hint": "Začíná na M."},
        {"id": "AJ4-07-03-011", "type": "choice", "question": "Jak se řekne anglicky 'tělocvična'?", "options": ["classroom", "canteen", "gym", "library", "playground"], "answer": "gym", "hint": "Tři písmenka."},
        {"id": "AJ4-07-03-012", "type": "choice", "question": "Jak se řekne anglicky 'hřiště'?", "options": ["gym", "garden", "playground", "park", "yard"], "answer": "playground", "hint": "Play + ground."},
        {"id": "AJ4-07-03-013", "type": "choice", "question": "Co znamená 'teacher'?", "options": ["žák", "ředitel", "učitel", "spolužák", "rodič"], "answer": "učitel", "hint": "Učí nás ve škole."},
        {"id": "AJ4-07-03-014", "type": "choice", "question": "Co znamená 'pupil' nebo 'student'?", "options": ["učitel", "ředitel", "žák", "uklízečka", "kuchařka"], "answer": "žák", "hint": "Chodí do školy a učí se."},
        {"id": "AJ4-07-03-015", "type": "choice", "question": "Co znamená 'homework'?", "options": ["test", "domácí úkol", "projekt", "vysvědčení", "přestávka"], "answer": "domácí úkol", "hint": "Home = doma, work = práce."}
      ]
    },
    {
      "id": "AJ4-07-04",
      "name": "Pokyny učitele",
      "difficulty": 2,
      "theory": "Pokyny ve škole: Open your books. Close your books. Listen! Look! Sit down. Stand up. Be quiet! Raise your hand. Write. Read. Repeat after me.",
      "tasks": [
        {"id": "AJ4-07-04-001", "type": "choice", "question": "Co znamená 'Open your books!'?", "options": ["Zavřete knihy!", "Otevřete knihy!", "Čtěte!", "Pište!", "Vezměte si knihy!"], "answer": "Otevřete knihy!", "hint": "Open = otevřít."},
        {"id": "AJ4-07-04-002", "type": "choice", "question": "Co znamená 'Close your books!'?", "options": ["Otevřete knihy!", "Čtěte knihy!", "Zavřete knihy!", "Schovejte knihy!", "Vraťte knihy!"], "answer": "Zavřete knihy!", "hint": "Close = zavřít."},
        {"id": "AJ4-07-04-003", "type": "choice", "question": "Co znamená 'Listen!'?", "options": ["Dívejte se!", "Poslouchejte!", "Čtěte!", "Pište!", "Mlčte!"], "answer": "Poslouchejte!", "hint": "Listen = poslouchat."},
        {"id": "AJ4-07-04-004", "type": "choice", "question": "Co znamená 'Sit down!'?", "options": ["Vstávejte!", "Sedněte si!", "Pojďte sem!", "Jděte ven!", "Běžte!"], "answer": "Sedněte si!", "hint": "Sit = sedět, down = dolů."},
        {"id": "AJ4-07-04-005", "type": "choice", "question": "Co znamená 'Stand up!'?", "options": ["Sedněte si!", "Lehněte si!", "Vstávejte!", "Běžte!", "Skočte!"], "answer": "Vstávejte!", "hint": "Stand = stát, up = nahoru."},
        {"id": "AJ4-07-04-006", "type": "choice", "question": "Co znamená 'Be quiet!'?", "options": ["Mluvte!", "Buďte ticho!", "Poslouchejte!", "Čtěte!", "Zpívejte!"], "answer": "Buďte ticho!", "hint": "Quiet = tichý."},
        {"id": "AJ4-07-04-007", "type": "choice", "question": "Co znamená 'Raise your hand!'?", "options": ["Umyjte si ruce!", "Zvedněte ruku!", "Tleskněte!", "Podejte si ruce!", "Schovejte ruce!"], "answer": "Zvedněte ruku!", "hint": "Raise = zvednout."},
        {"id": "AJ4-07-04-008", "type": "choice", "question": "Co znamená 'Repeat after me!'?", "options": ["Čtěte za mnou!", "Opakujte po mně!", "Jděte za mnou!", "Pište za mnou!", "Běžte za mnou!"], "answer": "Opakujte po mně!", "hint": "Repeat = opakovat."},
        {"id": "AJ4-07-04-009", "type": "choice", "question": "Co znamená 'Write in your notebooks!'?", "options": ["Čtěte sešity!", "Otevřete sešity!", "Pište do sešitů!", "Zavřete sešity!", "Schovejte sešity!"], "answer": "Pište do sešitů!", "hint": "Write = psát."},
        {"id": "AJ4-07-04-010", "type": "choice", "question": "Co znamená 'Read page five!'?", "options": ["Pište stránku pět!", "Čtěte stránku pět!", "Otevřete stránku pět!", "Zavřete stránku pět!", "Nakreslete stránku pět!"], "answer": "Čtěte stránku pět!", "hint": "Read = číst, page = stránka."},
        {"id": "AJ4-07-04-011", "type": "choice", "question": "Co znamená 'Look at the board!'?", "options": ["Pište na tabuli!", "Čtěte z tabule!", "Dívejte se na tabuli!", "Otřete tabuli!", "Jděte k tabuli!"], "answer": "Dívejte se na tabuli!", "hint": "Look = dívat se."},
        {"id": "AJ4-07-04-012", "type": "choice", "question": "Co znamená 'Come here!'?", "options": ["Jdi pryč!", "Sedni si!", "Pojď sem!", "Počkej!", "Běž domů!"], "answer": "Pojď sem!", "hint": "Come = pojď, here = sem."},
        {"id": "AJ4-07-04-013", "type": "choice", "question": "Jak řekneš 'Můžu jít na záchod?'?", "options": ["Can I go home?", "Can I go to the toilet?", "Can I go to the gym?", "Can I go outside?", "Can I go to the canteen?"], "answer": "Can I go to the toilet?", "hint": "Toilet = záchod."},
        {"id": "AJ4-07-04-014", "type": "choice", "question": "Co znamená 'May I come in?'?", "options": ["Můžu jít ven?", "Můžu vstoupit?", "Můžu odejít?", "Můžu si sednout?", "Můžu jít domů?"], "answer": "Můžu vstoupit?", "hint": "Come in = vstoupit."},
        {"id": "AJ4-07-04-015", "type": "choice", "question": "Co znamená 'Well done!'?", "options": ["Špatně!", "Zkus to znovu!", "Výborně!", "Pozor!", "Ticho!"], "answer": "Výborně!", "hint": "Učitel chválí."}
      ]
    },
    {
      "id": "AJ4-07-05",
      "name": "Škola — věty a situace",
      "difficulty": 2,
      "theory": "Věty o škole: I go to school. My favourite subject is... I have got maths on Monday. Break/recess = přestávka. Lesson = hodina. Timetable = rozvrh.",
      "tasks": [
        {"id": "AJ4-07-05-001", "type": "choice", "question": "Co znamená 'I go to school every day'?", "options": ["Chodím do školy každý den.", "Mám rád školu.", "Škola je každý den.", "Jdu ze školy.", "Jsem ve škole."], "answer": "Chodím do školy každý den.", "hint": "Go to school = chodit do školy."},
        {"id": "AJ4-07-05-002", "type": "choice", "question": "Co znamená 'break' nebo 'recess'?", "options": ["hodina", "oběd", "přestávka", "test", "konec"], "answer": "přestávka", "hint": "Čas mezi hodinami na odpočinek."},
        {"id": "AJ4-07-05-003", "type": "choice", "question": "Co znamená 'lesson'?", "options": ["přestávka", "vyučovací hodina", "test", "domácí úkol", "vysvědčení"], "answer": "vyučovací hodina", "hint": "45 minut učení."},
        {"id": "AJ4-07-05-004", "type": "choice", "question": "Co znamená 'timetable'?", "options": ["hodiny", "kalendář", "rozvrh", "deník", "plán"], "answer": "rozvrh", "hint": "Time = čas, table = tabulka → rozvrh hodin."},
        {"id": "AJ4-07-05-005", "type": "choice", "question": "Jak řekneš 'Můj oblíbený předmět je matematika'?", "options": ["I like maths.", "My favourite subject is maths.", "Maths is good.", "I have maths.", "I go to maths."], "answer": "My favourite subject is maths.", "hint": "Favourite subject = oblíbený předmět."},
        {"id": "AJ4-07-05-006", "type": "choice", "question": "Co znamená 'I have English on Wednesdays'?", "options": ["Mám rád angličtinu.", "Angličtina je ve středu.", "Mám angličtinu ve středu.", "Učím se anglicky.", "Angličtinu jsem měl ve středu."], "answer": "Mám angličtinu ve středu.", "hint": "I have = mám (v rozvrhu), Wednesday = středa."},
        {"id": "AJ4-07-05-007", "type": "choice", "question": "Co znamená 'test'?", "options": ["domácí úkol", "test/písemka", "přestávka", "hodina", "projekt"], "answer": "test/písemka", "hint": "Učitel zkouší co umíme."},
        {"id": "AJ4-07-05-008", "type": "choice", "question": "Co znamená 'I'm late!'?", "options": ["Jsem unavený!", "Jdu pozdě!", "Jsem připravený!", "Jsem nemocný!", "Jsem tady!"], "answer": "Jdu pozdě!", "hint": "Late = pozdě."},
        {"id": "AJ4-07-05-009", "type": "choice", "question": "Co znamená 'school starts at eight o'clock'?", "options": ["Škola končí v osm.", "Škola začíná v osm.", "Škola je v osm hodin.", "Mám osm hodin.", "Přestávka je v osm."], "answer": "Škola začíná v osm.", "hint": "Starts = začíná, eight o'clock = v osm hodin."},
        {"id": "AJ4-07-05-010", "type": "choice", "question": "Jak řekneš 'Nemám rád testy'?", "options": ["I like tests.", "I am not tests.", "I don't like tests.", "I haven't got tests.", "Tests are not good."], "answer": "I don't like tests.", "hint": "I don't like = nemám rád."}
      ]
    },
