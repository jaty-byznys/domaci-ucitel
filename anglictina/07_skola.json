        {"id": "AJ4-07-06-002", "type": "choice", "question": "Kde jíme oběd ve škole?", "options": ["in the classroom", "in the gym", "in the library", "in the canteen", "in the corridor"], "answer": "in the canteen", "hint": "Canteen = jídelna."},
        {"id": "AJ4-07-06-003", "type": "choice", "question": "Kde cvičíme?", "options": ["in the canteen", "in the library", "in the gym", "in the classroom", "in the corridor"], "answer": "in the gym", "hint": "Gym = tělocvična."},
        {"id": "AJ4-07-06-004", "type": "choice", "question": "Co znamená 'backpack'?", "options": ["penál", "batoh", "taška", "kufr", "sáček"], "answer": "batoh", "hint": "Back = záda, pack = balík → batoh."},
        {"id": "AJ4-07-06-005", "type": "choice", "question": "Co znamená 'textbook'?", "options": ["sešit", "učebnice", "slovník", "atlas", "pracovní list"], "answer": "učebnice", "hint": "Text + book = kniha s textem k učení."},
