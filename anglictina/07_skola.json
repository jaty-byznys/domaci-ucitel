  "skills": [
    {
      "id": "AJ4-07-01",
      "name": "Školní potřeby — překlad",
      "difficulty": 1,
      "theory": "Školní potřeby: book = kniha, pen = pero, pencil = tužka, rubber/eraser = guma, ruler = pravítko, bag = taška, desk = lavice, chair = židle, board = tabule, classroom = třída/učebna, notebook = sešit, pencil case = penál, scissors = nůžky, glue = lepidlo, sharpener = ořezávátko.",
      "tasks": [
        {"id": "AJ4-07-01-001", "type": "choice", "question": "Co znamená 'book'?", "options": ["sešit", "kniha", "penál", "taška", "deník"], "answer": "kniha", "hint": "Čteme ji."},
        {"id": "AJ4-07-01-002", "type": "choice", "question": "Co znamená 'pen'?", "options": ["tužka", "pero", "fix", "křída", "pastelka"], "answer": "pero", "hint": "Píšeme jím inkoustem."},
        {"id": "AJ4-07-01-003", "type": "choice", "question": "Co znamená 'pencil'?", "options": ["pero", "tužka", "fix", "pastelka", "křída"], "answer": "tužka", "hint": "Dá se gumovat."},
        {"id": "AJ4-07-01-004", "type": "choice", "question": "Co znamená 'rubber'?", "options": ["pravítko", "tužka", "guma", "lepidlo", "nůžky"], "answer": "guma", "hint": "Mažeme jí chyby."},
        {"id": "AJ4-07-01-005", "type": "choice", "question": "Co znamená 'ruler'?", "options": ["guma", "pravítko", "kružítko", "nůžky", "pero"], "answer": "pravítko", "hint": "Měříme a rýsujeme jím."},
        {"id": "AJ4-07-01-006", "type": "choice", "question": "Co znamená 'bag'?", "options": ["penál", "taška", "krabice", "batoh", "sáček"], "answer": "taška", "hint": "Nosíme v ní věci do školy."},
        {"id": "AJ4-07-01-007", "type": "choice", "question": "Co znamená 'desk'?", "options": ["židle", "tabule", "lavice/stůl", "skříň", "polička"], "answer": "lavice/stůl", "hint": "Sedíme u ní a píšeme."},
        {"id": "AJ4-07-01-008", "type": "choice", "question": "Co znamená 'chair'?", "options": ["stůl", "lavice", "židle", "tabule", "skříň"], "answer": "židle", "hint": "Sedíme na ní."},
        {"id": "AJ4-07-01-009", "type": "choice", "question": "Co znamená 'board'?", "options": ["podlaha", "stěna", "tabule", "dveře", "okno"], "answer": "tabule", "hint": "Učitel na ni píše."},
        {"id": "AJ4-07-01-010", "type": "choice", "question": "Co znamená 'classroom'?", "options": ["chodba", "jídelna", "tělocvična", "třída/učebna", "knihovna"], "answer": "třída/učebna", "hint": "Class + room = místnost kde se učíme."},
        {"id": "AJ4-07-01-011", "type": "choice", "question": "Co znamená 'notebook'?", "options": ["kniha", "sešit", "penál", "deník", "učebnice"], "answer": "sešit", "hint": "Píšeme do něj poznámky."},
        {"id": "AJ4-07-01-012", "type": "choice", "question": "Co znamená 'pencil case'?", "options": ["taška", "krabice", "penál", "pouzdro", "sešit"], "answer": "penál", "hint": "Pencil = tužka, case = pouzdro."},
        {"id": "AJ4-07-01-013", "type": "choice", "question": "Co znamená 'scissors'?", "options": ["pravítko", "lepidlo", "nůžky", "sešívačka", "guma"], "answer": "nůžky", "hint": "Stříháme jimi papír."},
        {"id": "AJ4-07-01-014", "type": "choice", "question": "Co znamená 'glue'?", "options": ["nůžky", "lepidlo", "barva", "křída", "fix"], "answer": "lepidlo", "hint": "Lepíme jím papír."},
        {"id": "AJ4-07-01-015", "type": "choice", "question": "Co znamená 'sharpener'?", "options": ["guma", "pravítko", "ořezávátko", "nůžky", "lepidlo"], "answer": "ořezávátko", "hint": "Sharp = ostrý. Ostříme jím tužku."}
      ]
    },
    {
      "id": "AJ4-07-02",
