{
  "id": "AJ4-02",
  "name": "Rodina",
  "order": 1,
  "prerequisite": null,
  "skills": [
    {
      "id": "AJ4-02-01",
      "name": "Členové rodiny — překlad",
      "difficulty": 1,
      "theory": "Rodina anglicky: mother/mum = máma, father/dad = táta, brother = bratr, sister = sestra, grandmother/grandma = babička, grandfather/grandpa = dědeček, baby = miminko, family = rodina, parents = rodiče, children = děti, son = syn, daughter = dcera, uncle = strýc, aunt = teta, cousin = bratranec/sestřenice.",
      "tasks": [
        {"id": "AJ4-02-01-001", "type": "choice", "question": "Co znamená 'mother'?", "options": ["sestra", "máma", "babička", "teta", "dcera"], "answer": "máma", "hint": "Zkratka je 'mum'."},
        {"id": "AJ4-02-01-002", "type": "choice", "question": "Co znamená 'father'?", "options": ["bratr", "dědeček", "táta", "strýc", "syn"], "answer": "táta", "hint": "Zkratka je 'dad'."},
        {"id": "AJ4-02-01-003", "type": "choice", "question": "Co znamená 'brother'?", "options": ["bratr", "táta", "syn", "bratranec", "dědeček"], "answer": "bratr", "hint": "Mužský sourozenec."},
        {"id": "AJ4-02-01-004", "type": "choice", "question": "Co znamená 'sister'?", "options": ["teta", "máma", "sestřenice", "sestra", "dcera"], "answer": "sestra", "hint": "Ženský sourozenec."},
        {"id": "AJ4-02-01-005", "type": "choice", "question": "Co znamená 'grandmother'?", "options": ["máma", "teta", "babička", "sestra", "dcera"], "answer": "babička", "hint": "Grand + mother. Zkratka je 'grandma'."},
        {"id": "AJ4-02-01-006", "type": "choice", "question": "Co znamená 'grandfather'?", "options": ["táta", "strýc", "bratr", "dědeček", "syn"], "answer": "dědeček", "hint": "Grand + father. Zkratka je 'grandpa'."},
        {"id": "AJ4-02-01-007", "type": "choice", "question": "Co znamená 'baby'?", "options": ["dítě", "miminko", "syn", "dcera", "bratranec"], "answer": "miminko", "hint": "Úplně malé dítě."},
        {"id": "AJ4-02-01-008", "type": "choice", "question": "Co znamená 'family'?", "options": ["přátelé", "škola", "rodina", "sousedé", "třída"], "answer": "rodina", "hint": "Máma, táta, děti dohromady."},
        {"id": "AJ4-02-01-009", "type": "choice", "question": "Co znamená 'son'?", "options": ["slunce", "syn", "bratr", "dcera", "bratranec"], "answer": "syn", "hint": "Neplést se 'sun' (slunce)! Son = syn."},
        {"id": "AJ4-02-01-010", "type": "choice", "question": "Co znamená 'daughter'?", "options": ["dcera", "sestra", "teta", "máma", "babička"], "answer": "dcera", "hint": "Ženské dítě rodičů."},
        {"id": "AJ4-02-01-011", "type": "choice", "question": "Co znamená 'parents'?", "options": ["děti", "sourozenci", "prarodiče", "rodiče", "příbuzní"], "answer": "rodiče", "hint": "Máma a táta dohromady."},
        {"id": "AJ4-02-01-012", "type": "choice", "question": "Co znamená 'children'?", "options": ["rodiče", "děti", "sourozenci", "přátelé", "prarodiče"], "answer": "děti", "hint": "Množné číslo od 'child'."},
        {"id": "AJ4-02-01-013", "type": "choice", "question": "Co znamená 'uncle'?", "options": ["dědeček", "bratr", "strýc", "bratranec", "táta"], "answer": "strýc", "hint": "Bratr tvé mámy nebo táty."},
        {"id": "AJ4-02-01-014", "type": "choice", "question": "Co znamená 'aunt'?", "options": ["babička", "sestra", "sestřenice", "teta", "máma"], "answer": "teta", "hint": "Sestra tvé mámy nebo táty."},
        {"id": "AJ4-02-01-015", "type": "choice", "question": "Co znamená 'cousin'?", "options": ["bratr", "soused", "bratranec nebo sestřenice", "kamarád", "syn"], "answer": "bratranec nebo sestřenice", "hint": "Dítě tvého strýce nebo tety."},
        {"id": "AJ4-02-01-016", "type": "choice", "question": "Co znamená 'grandma'?", "options": ["máma", "babička", "teta", "sestra", "dcera"], "answer": "babička", "hint": "Zkrácený tvar grandmother."},
        {"id": "AJ4-02-01-017", "type": "choice", "question": "Co znamená 'dad'?", "options": ["dědeček", "bratr", "strýc", "táta", "syn"], "answer": "táta", "hint": "Zkrácený tvar father."},
        {"id": "AJ4-02-01-018", "type": "choice", "question": "Co znamená 'grandpa'?", "options": ["táta", "dědeček", "strýc", "bratr", "bratranec"], "answer": "dědeček", "hint": "Zkrácený tvar grandfather."},
        {"id": "AJ4-02-01-019", "type": "choice", "question": "Co znamená 'mum'?", "options": ["babička", "teta", "máma", "sestra", "dcera"], "answer": "máma", "hint": "Zkrácený tvar mother."}
      ]
    },
    {
      "id": "AJ4-02-02",
      "name": "Členové rodiny — česky → anglicky",
      "difficulty": 1,
      "theory": "Teď to zkusíme obráceně — z češtiny do angličtiny!",
      "tasks": [
        {"id": "AJ4-02-02-001", "type": "choice", "question": "Jak se řekne anglicky 'máma'?", "options": ["sister", "mother", "grandmother", "daughter", "aunt"], "answer": "mother", "hint": "Nebo zkráceně 'mum'."},
        {"id": "AJ4-02-02-002", "type": "choice", "question": "Jak se řekne anglicky 'táta'?", "options": ["brother", "uncle", "grandfather", "father", "son"], "answer": "father", "hint": "Nebo zkráceně 'dad'."},
        {"id": "AJ4-02-02-003", "type": "choice", "question": "Jak se řekne anglicky 'bratr'?", "options": ["brother", "father", "cousin", "son", "uncle"], "answer": "brother", "hint": "Začíná na B."},
        {"id": "AJ4-02-02-004", "type": "choice", "question": "Jak se řekne anglicky 'sestra'?", "options": ["daughter", "aunt", "cousin", "mother", "sister"], "answer": "sister", "hint": "Začíná na S."},
        {"id": "AJ4-02-02-005", "type": "choice", "question": "Jak se řekne anglicky 'babička'?", "options": ["mother", "aunt", "grandmother", "sister", "daughter"], "answer": "grandmother", "hint": "Grand + mother."},
        {"id": "AJ4-02-02-006", "type": "choice", "question": "Jak se řekne anglicky 'dědeček'?", "options": ["father", "uncle", "brother", "grandfather", "son"], "answer": "grandfather", "hint": "Grand + father."},
        {"id": "AJ4-02-02-007", "type": "choice", "question": "Jak se řekne anglicky 'syn'?", "options": ["sun", "son", "brother", "boy", "cousin"], "answer": "son", "hint": "Pozor — neplést se 'sun' (slunce)."},
        {"id": "AJ4-02-02-008", "type": "choice", "question": "Jak se řekne anglicky 'dcera'?", "options": ["sister", "girl", "daughter", "aunt", "cousin"], "answer": "daughter", "hint": "Začíná na D."},
        {"id": "AJ4-02-02-009", "type": "choice", "question": "Jak se řekne anglicky 'rodina'?", "options": ["friends", "family", "parents", "children", "people"], "answer": "family", "hint": "Začíná na F."},
        {"id": "AJ4-02-02-010", "type": "choice", "question": "Jak se řekne anglicky 'rodiče'?", "options": ["children", "family", "grandparents", "parents", "cousins"], "answer": "parents", "hint": "Máma + táta = parents."},
        {"id": "AJ4-02-02-011", "type": "choice", "question": "Jak se řekne anglicky 'děti'?", "options": ["parents", "babies", "boys", "children", "cousins"], "answer": "children", "hint": "Jedno dítě = child, víc dětí = children."},
        {"id": "AJ4-02-02-012", "type": "choice", "question": "Jak se řekne anglicky 'strýc'?", "options": ["grandfather", "cousin", "uncle", "brother", "father"], "answer": "uncle", "hint": "Začíná na U."},
        {"id": "AJ4-02-02-013", "type": "choice", "question": "Jak se řekne anglicky 'teta'?", "options": ["grandmother", "sister", "cousin", "aunt", "mother"], "answer": "aunt", "hint": "Začíná na A."},
        {"id": "AJ4-02-02-014", "type": "choice", "question": "Jak se řekne anglicky 'miminko'?", "options": ["child", "boy", "baby", "son", "daughter"], "answer": "baby", "hint": "Začíná na B."},
        {"id": "AJ4-02-02-015", "type": "choice", "question": "Jak se řekne anglicky 'bratranec'?", "options": ["brother", "uncle", "nephew", "cousin", "friend"], "answer": "cousin", "hint": "Platí pro bratrance i sestřenici."},
        {"id": "AJ4-02-02-016", "type": "choice", "question": "Jak se řekne anglicky 'prarodiče'?", "options": ["parents", "grandparents", "family", "uncles", "cousins"], "answer": "grandparents", "hint": "Grand + parents."}
      ]
    },
    {
      "id": "AJ4-02-03",
      "name": "Kdo je kdo v rodině",
      "difficulty": 2,
      "theory": "Umíš pojmenovat členy rodiny. Teď zkusíme poznat, kdo je kdo — podle popisu!",
      "tasks": [
        {"id": "AJ4-02-03-001", "type": "choice", "question": "Your mother's mother is your ___.", "options": ["mother", "aunt", "grandmother", "sister", "cousin"], "answer": "grandmother", "hint": "Máma tvojí mámy."},
        {"id": "AJ4-02-03-002", "type": "choice", "question": "Your father's brother is your ___.", "options": ["brother", "cousin", "grandfather", "uncle", "father"], "answer": "uncle", "hint": "Bratr tvého táty."},
        {"id": "AJ4-02-03-003", "type": "choice", "question": "Your mother's sister is your ___.", "options": ["sister", "grandmother", "cousin", "aunt", "mother"], "answer": "aunt", "hint": "Sestra tvojí mámy."},
        {"id": "AJ4-02-03-004", "type": "choice", "question": "Your uncle's son is your ___.", "options": ["brother", "nephew", "cousin", "son", "uncle"], "answer": "cousin", "hint": "Syn tvého strýce."},
        {"id": "AJ4-02-03-005", "type": "choice", "question": "Your father's father is your ___.", "options": ["father", "uncle", "grandfather", "brother", "grandson"], "answer": "grandfather", "hint": "Táta tvého táty."},
        {"id": "AJ4-02-03-006", "type": "choice", "question": "Your parents' parents are your ___.", "options": ["parents", "aunts", "uncles", "cousins", "grandparents"], "answer": "grandparents", "hint": "Rodiče tvých rodičů."},
        {"id": "AJ4-02-03-007", "type": "choice", "question": "Your mother and father are your ___.", "options": ["children", "grandparents", "parents", "family", "brothers"], "answer": "parents", "hint": "Máma + táta = ?"},
        {"id": "AJ4-02-03-008", "type": "choice", "question": "You are your parents' ___.", "options": ["parent", "cousin", "uncle", "child", "grandchild"], "answer": "child", "hint": "Ty jsi dítě svých rodičů."},
        {"id": "AJ4-02-03-009", "type": "choice", "question": "Your grandmother's son is your ___ or your uncle.", "options": ["brother", "father", "grandfather", "cousin", "son"], "answer": "father", "hint": "Syn tvojí babičky může být tvůj táta."},
        {"id": "AJ4-02-03-010", "type": "choice", "question": "A boy baby is a ___.", "options": ["daughter", "girl", "son", "brother", "cousin"], "answer": "son", "hint": "Chlapec = syn."},
        {"id": "AJ4-02-03-011", "type": "choice", "question": "A girl baby is a ___.", "options": ["son", "sister", "aunt", "daughter", "cousin"], "answer": "daughter", "hint": "Děvče = dcera."},
        {"id": "AJ4-02-03-012", "type": "choice", "question": "Your sister's daughter is your ___.", "options": ["cousin", "niece", "daughter", "aunt", "sister"], "answer": "niece", "hint": "Dcera tvojí sestry = neteř."},
        {"id": "AJ4-02-03-013", "type": "choice", "question": "Your brother's son is your ___.", "options": ["cousin", "son", "brother", "nephew", "uncle"], "answer": "nephew", "hint": "Syn tvého bratra = synovec."},
        {"id": "AJ4-02-03-014", "type": "choice", "question": "Tom has a sister. Tom is her ___.", "options": ["sister", "father", "cousin", "brother", "son"], "answer": "brother", "hint": "Tom je kluk, takže je její bratr."},
        {"id": "AJ4-02-03-015", "type": "choice", "question": "Anna has a brother. Anna is his ___.", "options": ["brother", "mother", "sister", "aunt", "daughter"], "answer": "sister", "hint": "Anna je holka, takže je jeho sestra."}
      ]
    },
    {
      "id": "AJ4-02-04",
      "name": "Věty o rodině",
      "difficulty": 2,
      "theory": "Teď se naučíme říkat jednoduché věty o rodině: I have got a brother. My mum is nice. She is my sister.",
      "tasks": [
        {"id": "AJ4-02-04-001", "type": "choice", "question": "Jak řekneš 'Mám bratra'?", "options": ["I am a brother.", "I have got a brother.", "My brother is.", "I got brother.", "I has a brother."], "answer": "I have got a brother.", "hint": "Mám = I have got."},
        {"id": "AJ4-02-04-002", "type": "choice", "question": "Jak řekneš 'Mám sestru'?", "options": ["I have got a sister.", "I am a sister.", "She is my sister.", "I has a sister.", "My sister have."], "answer": "I have got a sister.", "hint": "Mám = I have got."},
        {"id": "AJ4-02-04-003", "type": "choice", "question": "Jak řekneš 'Nemám bratra'?", "options": ["I not have brother.", "I don't has a brother.", "I haven't got a brother.", "I am not brother.", "I no brother."], "answer": "I haven't got a brother.", "hint": "Nemám = I haven't got."},
        {"id": "AJ4-02-04-004", "type": "choice", "question": "Co znamená 'She is my mum'?", "options": ["Ona má mámu.", "Ona je moje máma.", "Ona je tvoje máma.", "Moje máma je ona.", "Já jsem máma."], "answer": "Ona je moje máma.", "hint": "She = ona, is = je, my = moje."},
        {"id": "AJ4-02-04-005", "type": "choice", "question": "Co znamená 'He is my dad'?", "options": ["On má tátu.", "On je tvůj táta.", "On je můj táta.", "Můj táta je on.", "Já jsem táta."], "answer": "On je můj táta.", "hint": "He = on, is = je, my = můj."},
        {"id": "AJ4-02-04-006", "type": "choice", "question": "Co znamená 'I have got two sisters'?", "options": ["Mám dvě sestry.", "Mám dva bratry.", "Ona má dvě sestry.", "Mám tři sestry.", "Jsem dvě sestry."], "answer": "Mám dvě sestry.", "hint": "Two sisters = dvě sestry."},
        {"id": "AJ4-02-04-007", "type": "choice", "question": "Doplň: 'My grandmother ___ very nice.'", "options": ["am", "are", "have", "is", "has"], "answer": "is", "hint": "My grandmother = ona → is."},
        {"id": "AJ4-02-04-008", "type": "choice", "question": "Doplň: 'My parents ___ tall.'", "options": ["is", "am", "are", "has", "have"], "answer": "are", "hint": "Parents = oni → are."},
        {"id": "AJ4-02-04-009", "type": "choice", "question": "Doplň: 'I ___ got a big family.'", "options": ["has", "is", "am", "have", "are"], "answer": "have", "hint": "I → have got."},
        {"id": "AJ4-02-04-010", "type": "choice", "question": "Doplň: 'My brother ___ got a dog.'", "options": ["have", "am", "is", "are", "has"], "answer": "has", "hint": "My brother = he → has got."},
        {"id": "AJ4-02-04-011", "type": "choice", "question": "Co znamená 'Have you got a brother?'", "options": ["Máš rád bratra?", "Jsi bratr?", "Máš bratra?", "Kde je tvůj bratr?", "Kdo je tvůj bratr?"], "answer": "Máš bratra?", "hint": "Have you got = máš?"},
        {"id": "AJ4-02-04-012", "type": "choice", "question": "Jak odpovíš 'Ano, mám' na otázku 'Have you got a sister?'?", "options": ["Yes, I am.", "Yes, I have.", "Yes, I do.", "Yes, she is.", "Yes, I got."], "answer": "Yes, I have.", "hint": "Have you got? → Yes, I have."},
        {"id": "AJ4-02-04-013", "type": "choice", "question": "Jak odpovíš 'Ne, nemám' na otázku 'Have you got a brother?'?", "options": ["No, I am not.", "No, I don't.", "No, I haven't.", "No, he isn't.", "No, I not."], "answer": "No, I haven't.", "hint": "Have you got? → No, I haven't."},
        {"id": "AJ4-02-04-014", "type": "choice", "question": "Co znamená 'My family is big'?", "options": ["Moje rodina je malá.", "Moje rodina je hezká.", "Máme rodinu.", "Moje rodina je velká.", "Velká rodina."], "answer": "Moje rodina je velká.", "hint": "Big = velký."},
        {"id": "AJ4-02-04-015", "type": "choice", "question": "Co znamená 'My sister is three years old'?", "options": ["Mám tři sestry.", "Moje sestra má tři hračky.", "Moje sestra má tři roky.", "Třetí sestra je stará.", "Moje sestra je třináct."], "answer": "Moje sestra má tři roky.", "hint": "Three years old = tři roky stará."},
        {"id": "AJ4-02-04-016", "type": "choice", "question": "Jak řekneš 'Moje máma je hodná'?", "options": ["My mum is nice.", "My mum are nice.", "I am nice mum.", "My nice mum.", "Mum is my nice."], "answer": "My mum is nice.", "hint": "Moje = my, máma = mum, je = is, hodná = nice."},
        {"id": "AJ4-02-04-017", "type": "choice", "question": "Jak řekneš 'Můj bratr je vysoký'?", "options": ["My brother are tall.", "My brother is tall.", "Brother my is tall.", "I am tall brother.", "My tall brother."], "answer": "My brother is tall.", "hint": "Můj bratr = my brother, je = is, vysoký = tall."},
        {"id": "AJ4-02-04-018", "type": "choice", "question": "Co znamená 'We are a happy family'?", "options": ["Máme šťastnou rodinu.", "Jsme šťastná rodina.", "Oni jsou šťastná rodina.", "Chceme šťastnou rodinu.", "Šťastná rodina jsme."], "answer": "Jsme šťastná rodina.", "hint": "We = my, are = jsme, happy = šťastný."},
        {"id": "AJ4-02-04-019", "type": "choice", "question": "Doplň: '___ is your favourite aunt?'", "options": ["What", "Where", "Who", "How", "When"], "answer": "Who", "hint": "Ptáme se na osobu — kdo."},
        {"id": "AJ4-02-04-020", "type": "choice", "question": "Co znamená 'I love my grandma'?", "options": ["Mám ráda svou tetu.", "Miluju svou babičku.", "Moje babička mě miluje.", "Miluju svou mámu.", "Babička mě má ráda."], "answer": "Miluju svou babičku.", "hint": "I love = miluju, my grandma = moje babička."}
      ]
    },
    {
      "id": "AJ4-02-05",
      "name": "Rodina — mix a opakování",
      "difficulty": 2,
      "theory": "Poslední blok — všechno dohromady!",
      "tasks": [
        {"id": "AJ4-02-05-001", "type": "choice", "question": "Které slovo NEPATŘÍ do rodiny?", "options": ["mother", "teacher", "father", "sister", "brother"], "answer": "teacher", "hint": "Teacher = učitel — to není člen rodiny."},
        {"id": "AJ4-02-05-002", "type": "choice", "question": "Které slovo NEPATŘÍ do rodiny?", "options": ["uncle", "aunt", "cousin", "friend", "grandmother"], "answer": "friend", "hint": "Friend = kamarád."},
        {"id": "AJ4-02-05-003", "type": "choice", "question": "Jak se řekne 'Kolik máš sourozenců?'", "options": ["How many brothers?", "How old are you?", "Have you got brothers and sisters?", "Who is your brother?", "Where is your sister?"], "answer": "Have you got brothers and sisters?", "hint": "Sourozenci = brothers and sisters."},
        {"id": "AJ4-02-05-004", "type": "choice", "question": "Tom: 'My mum's name is Anna.' Kdo je Anna?", "options": ["Tomova sestra", "Tomova máma", "Tomova babička", "Tomova teta", "Tomova dcera"], "answer": "Tomova máma", "hint": "My mum = moje máma."},
        {"id": "AJ4-02-05-005", "type": "choice", "question": "Jak se řekne 'starší bratr'?", "options": ["big brother", "old brother", "older brother", "tall brother", "large brother"], "answer": "older brother", "hint": "Older = starší."},
        {"id": "AJ4-02-05-006", "type": "choice", "question": "Jak se řekne 'mladší sestra'?", "options": ["small sister", "little sister", "younger sister", "short sister", "new sister"], "answer": "younger sister", "hint": "Younger = mladší."},
        {"id": "AJ4-02-05-007", "type": "choice", "question": "Co znamená 'twins'?", "options": ["sourozenci", "dvojčata", "kamarádi", "bratranec a sestřenice", "dva bratři"], "answer": "dvojčata", "hint": "Twin = dvojče."},
        {"id": "AJ4-02-05-008", "type": "choice", "question": "Co znamená 'only child'?", "options": ["malé dítě", "první dítě", "jedináček", "poslední dítě", "chytré dítě"], "answer": "jedináček", "hint": "Only = jediný, child = dítě."},
        {"id": "AJ4-02-05-009", "type": "choice", "question": "Doplň: 'My grandparents ___ in Prague.'", "options": ["lives", "live", "living", "is live", "are live"], "answer": "live", "hint": "Grandparents = oni → live (bez -s)."},
        {"id": "AJ4-02-05-010", "type": "choice", "question": "Doplň: 'My dad ___ in a hospital.'", "options": ["work", "works", "working", "is work", "are work"], "answer": "works", "hint": "My dad = he → works (s -s)."},
        {"id": "AJ4-02-05-011", "type": "choice", "question": "Co znamená 'My brother likes football'?", "options": ["Můj bratr hraje fotbal.", "Můj bratr má rád fotbal.", "Můj bratr nemá rád fotbal.", "Bratr má fotbalový míč.", "Můj bratr je fotbalista."], "answer": "Můj bratr má rád fotbal.", "hint": "Likes = má rád."},
