      "tasks": [
        {"id": "AJ4-15-05-001", "type": "choice", "question": "Přelož: 'Kočka je na stole.'", "options": ["The cat is in the table.", "The cat is under the table.", "The cat is on the table.", "The cat is behind the table.", "The cat is next to the table."], "answer": "The cat is on the table.", "hint": "Na = on."},
        {"id": "AJ4-15-05-002", "type": "choice", "question": "Přelož: 'Pes je pod postelí.'", "options": ["The dog is on the bed.", "The dog is in the bed.", "The dog is under the bed.", "The dog is behind the bed.", "The dog is next to the bed."], "answer": "The dog is under the bed.", "hint": "Pod = under."},
        {"id": "AJ4-15-05-003", "type": "choice", "question": "Přelož: 'Knihy jsou v tašce.'", "options": ["The books are on the bag.", "The books are under the bag.", "The books are in the bag.", "The books are behind the bag.", "The books are next to the bag."], "answer": "The books are in the bag.", "hint": "V = in."},
        {"id": "AJ4-15-05-004", "type": "choice", "question": "Přelož: 'Auto stojí před domem.'", "options": ["The car is behind the house.", "The car is next to the house.", "The car is in front of the house.", "The car is in the house.", "The car is on the house."], "answer": "The car is in front of the house.", "hint": "Před = in front of."},
