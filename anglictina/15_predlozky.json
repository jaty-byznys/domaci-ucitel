        {"id": "AJ4-15-04-008", "type": "choice", "question": "Kde je obrázek? Na zdi.", "options": ["in the wall", "under the wall", "on the wall", "behind the wall", "next to the wall"], "answer": "on the wall", "hint": "Na povrchu = on."},
        {"id": "AJ4-15-04-009", "type": "choice", "question": "Kde je kočka? Pod stolem.", "options": ["in the table", "on the table", "under the table", "behind the table", "above the table"], "answer": "under the table", "hint": "Pod = under."},
        {"id": "AJ4-15-04-010", "type": "choice", "question": "Kde jsou klíče? V kapse.", "options": ["on the pocket", "under the pocket", "in the pocket", "behind the pocket", "next to the pocket"], "answer": "in the pocket", "hint": "Uvnitř = in."},
        {"id": "AJ4-15-04-011", "type": "choice", "question": "Kde je hodiny? Nad tabulí.", "options": ["under the blackboard", "on the blackboard", "above the blackboard", "behind the blackboard", "next to the blackboard"], "answer": "above the blackboard", "hint": "Nad = above."},
        {"id": "AJ4-15-04-012", "type": "choice", "question": "Kde je škola? Blízko parku.", "options": ["in the park", "on the park", "behind the park", "near the park", "between the park"], "answer": "near the park", "hint": "Blízko = near."},
        {"id": "AJ4-15-04-013", "type": "choice", "question": "Kde je pes? Za pohovkou.", "options": ["in front of the sofa", "next to the sofa", "behind the sofa", "on the sofa", "under the sofa"], "answer": "behind the sofa", "hint": "Za = behind."},
        {"id": "AJ4-15-04-014", "type": "choice", "question": "Kde stojí učitel? Před třídou.", "options": ["behind the class", "next to the class", "in front of the class", "in the class", "above the class"], "answer": "in front of the class", "hint": "Před = in front of."},
