        {"id": "AJ4-15-05-006", "type": "choice", "question": "Přelož: 'Sedím vedle Anny.'", "options": ["I sit behind Anna.", "I sit in front of Anna.", "I sit next to Anna.", "I sit between Anna.", "I sit above Anna."], "answer": "I sit next to Anna.", "hint": "Vedle = next to."},
        {"id": "AJ4-15-05-007", "type": "choice", "question": "Přelož: 'Obchod je mezi bankou a poštou.'", "options": ["The shop is next to the bank and the post office.", "The shop is behind the bank and the post office.", "The shop is between the bank and the post office.", "The shop is in front of the bank.", "The shop is near the bank."], "answer": "The shop is between the bank and the post office.", "hint": "Mezi = between."},
        {"id": "AJ4-15-05-008", "type": "choice", "question": "Přelož: 'Na zdi je obrázek.'", "options": ["There is a picture in the wall.", "There is a picture under the wall.", "There is a picture on the wall.", "There is a picture behind the wall.", "There is a picture next to the wall."], "answer": "There is a picture on the wall.", "hint": "Na = on."},
        {"id": "AJ4-15-05-009", "type": "choice", "question": "Přelož: 'Pod stolem je krabice.'", "options": ["There is a box on the table.", "There is a box in the table.", "There is a box under the table.", "There is a box behind the table.", "There is a box next to the table."], "answer": "There is a box under the table.", "hint": "Pod = under."},
