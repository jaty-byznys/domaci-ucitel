  "skills": [
    {
      "id": "AJ4-15-01",
      "name": "In, on, under – překlad",
      "difficulty": 1,
      "theory": "in = v, uvnitř (in the box, in the room). on = na (on the table, on the wall). under = pod (under the bed, under the chair).",
      "tasks": [
        {"id": "AJ4-15-01-001", "type": "choice", "question": "Co znamená 'in the box'?", "options": ["na krabici", "pod krabicí", "v krabici", "vedle krabice", "za krabicí"], "answer": "v krabici", "hint": "In = v, uvnitř."},
        {"id": "AJ4-15-01-002", "type": "choice", "question": "Co znamená 'on the table'?", "options": ["pod stolem", "v stole", "na stole", "vedle stolu", "za stolem"], "answer": "na stole", "hint": "On = na."},
        {"id": "AJ4-15-01-003", "type": "choice", "question": "Co znamená 'under the bed'?", "options": ["na posteli", "v posteli", "za postelí", "pod postelí", "vedle postele"], "answer": "pod postelí", "hint": "Under = pod."},
        {"id": "AJ4-15-01-004", "type": "choice", "question": "Jak řekneš anglicky 'v tašce'?", "options": ["on the bag", "under the bag", "in the bag", "next to the bag", "behind the bag"], "answer": "in the bag", "hint": "V = in."},
        {"id": "AJ4-15-01-005", "type": "choice", "question": "Jak řekneš anglicky 'na zdi'?", "options": ["in the wall", "under the wall", "on the wall", "next to the wall", "behind the wall"], "answer": "on the wall", "hint": "Na = on."},
        {"id": "AJ4-15-01-006", "type": "choice", "question": "Jak řekneš anglicky 'pod židlí'?", "options": ["on the chair", "in the chair", "under the chair", "next to the chair", "behind the chair"], "answer": "under the chair", "hint": "Pod = under."},
        {"id": "AJ4-15-01-007", "type": "choice", "question": "Doplň: 'The cat is ___ the sofa.' (na pohovce)", "options": ["in", "under", "on", "behind", "next to"], "answer": "on", "hint": "Na = on."},
        {"id": "AJ4-15-01-008", "type": "choice", "question": "Doplň: 'The ball is ___ the table.' (pod stolem)", "options": ["in", "on", "under", "behind", "next to"], "answer": "under", "hint": "Pod = under."},
        {"id": "AJ4-15-01-009", "type": "choice", "question": "Doplň: 'The keys are ___ the drawer.' (v šuplíku)", "options": ["on", "under", "in", "behind", "next to"], "answer": "in", "hint": "V = in."},
        {"id": "AJ4-15-01-010", "type": "choice", "question": "Doplň: 'The picture is ___ the wall.'", "options": ["in", "under", "on", "behind", "between"], "answer": "on", "hint": "Obrázek visí NA zdi."},
        {"id": "AJ4-15-01-011", "type": "choice", "question": "Doplň: 'The dog is ___ the bed.'  (pod postelí)", "options": ["in", "on", "under", "behind", "next to"], "answer": "under", "hint": "Pod = under."},
        {"id": "AJ4-15-01-012", "type": "choice", "question": "Doplň: 'The milk is ___ the fridge.'", "options": ["on", "under", "in", "behind", "next to"], "answer": "in", "hint": "Mléko je V lednici."},
        {"id": "AJ4-15-01-013", "type": "choice", "question": "Doplň: 'The book is ___ the desk.'  (na stole)", "options": ["in", "under", "on", "behind", "between"], "answer": "on", "hint": "Na = on."},
        {"id": "AJ4-15-01-014", "type": "choice", "question": "Doplň: 'The shoes are ___ the bed.' (pod postelí)", "options": ["in", "on", "under", "behind", "next to"], "answer": "under", "hint": "Pod = under."},
        {"id": "AJ4-15-01-015", "type": "choice", "question": "Doplň: 'The pen is ___ the pencil case.'", "options": ["on", "under", "in", "behind", "between"], "answer": "in", "hint": "Pero je V penále."},
        {"id": "AJ4-15-01-016", "type": "choice", "question": "Doplň: 'The lamp is ___ the table.'  (na stole)", "options": ["in", "under", "on", "behind", "between"], "answer": "on", "hint": "Lampa stojí NA stole."},
        {"id": "AJ4-15-01-017", "type": "choice", "question": "Co znamená 'in the car'?", "options": ["na autě", "pod autem", "v autě", "za autem", "vedle auta"], "answer": "v autě", "hint": "In = v, uvnitř."}
      ]
    },
    {
      "id": "AJ4-15-02",
      "name": "Next to, behind, in front of",
      "difficulty": 1,
      "theory": "next to = vedle (next to the school). behind = za (behind the house). in front of = před (in front of the shop).",
      "tasks": [
        {"id": "AJ4-15-02-001", "type": "choice", "question": "Co znamená 'next to the school'?", "options": ["za školou", "pod školou", "ve škole", "vedle školy", "před školou"], "answer": "vedle školy", "hint": "Next to = vedle."},
        {"id": "AJ4-15-02-002", "type": "choice", "question": "Co znamená 'behind the house'?", "options": ["vedle domu", "před domem", "za domem", "v domě", "nad domem"], "answer": "za domem", "hint": "Behind = za."},
        {"id": "AJ4-15-02-003", "type": "choice", "question": "Co znamená 'in front of the shop'?", "options": ["za obchodem", "vedle obchodu", "před obchodem", "v obchodě", "nad obchodem"], "answer": "před obchodem", "hint": "In front of = před."},
        {"id": "AJ4-15-02-004", "type": "choice", "question": "Jak řekneš anglicky 'vedle parku'?", "options": ["behind the park", "in front of the park", "next to the park", "in the park", "under the park"], "answer": "next to the park", "hint": "Vedle = next to."},
        {"id": "AJ4-15-02-005", "type": "choice", "question": "Jak řekneš anglicky 'za stromem'?", "options": ["next to the tree", "in front of the tree", "behind the tree", "in the tree", "under the tree"], "answer": "behind the tree", "hint": "Za = behind."},
        {"id": "AJ4-15-02-006", "type": "choice", "question": "Jak řekneš anglicky 'před školou'?", "options": ["behind the school", "next to the school", "in front of the school", "in the school", "on the school"], "answer": "in front of the school", "hint": "Před = in front of."},
        {"id": "AJ4-15-02-007", "type": "choice", "question": "Doplň: 'The cat is ___ the door.' (za dveřmi)", "options": ["in", "on", "next to", "behind", "under"], "answer": "behind", "hint": "Za = behind."},
        {"id": "AJ4-15-02-008", "type": "choice", "question": "Doplň: 'The car is ___ the house.' (před domem)", "options": ["behind", "next to", "in front of", "in", "under"], "answer": "in front of", "hint": "Před = in front of."},
        {"id": "AJ4-15-02-009", "type": "choice", "question": "Doplň: 'I sit ___ Tom.' (vedle Toma)", "options": ["behind", "in front of", "next to", "in", "under"], "answer": "next to", "hint": "Vedle = next to."},
        {"id": "AJ4-15-02-010", "type": "choice", "question": "Doplň: 'The garden is ___ the house.' (za domem)", "options": ["in front of", "next to", "behind", "in", "on"], "answer": "behind", "hint": "Zahrada je ZA domem."},
        {"id": "AJ4-15-02-011", "type": "choice", "question": "Doplň: 'The bus stop is ___ the school.' (před školou)", "options": ["behind", "next to", "in front of", "in", "under"], "answer": "in front of", "hint": "Zastávka je PŘED školou."},
        {"id": "AJ4-15-02-012", "type": "choice", "question": "Doplň: 'The pharmacy is ___ the supermarket.' (vedle supermarketu)", "options": ["behind", "in front of", "next to", "in", "under"], "answer": "next to", "hint": "Lékárna je VEDLE supermarketu."},
        {"id": "AJ4-15-02-013", "type": "choice", "question": "Co znamená 'The dog is behind the sofa'?", "options": ["Pes je na pohovce.", "Pes je pod pohovkou.", "Pes je za pohovkou.", "Pes je vedle pohovky.", "Pes je před pohovkou."], "answer": "Pes je za pohovkou.", "hint": "Behind = za."},
        {"id": "AJ4-15-02-014", "type": "choice", "question": "Co znamená 'The teacher is in front of the class'?", "options": ["Učitel je za třídou.", "Učitel je vedle třídy.", "Učitel je před třídou.", "Učitel je ve třídě.", "Učitel je nad třídou."], "answer": "Učitel je před třídou.", "hint": "In front of = před."},
        {"id": "AJ4-15-02-015", "type": "choice", "question": "Doplň: 'My friend sits ___ me in class.' (za mnou)", "options": ["in front of", "next to", "behind", "in", "under"], "answer": "behind", "hint": "Za mnou = behind me."},
        {"id": "AJ4-15-02-016", "type": "choice", "question": "Doplň: 'The bank is ___ the post office.' (vedle pošty)", "options": ["behind", "in front of", "next to", "in", "under"], "answer": "next to", "hint": "Vedle = next to."},
        {"id": "AJ4-15-02-017", "type": "choice", "question": "Doplň: 'There is a tree ___ the house.' (před domem)", "options": ["behind", "next to", "in front of", "in", "under"], "answer": "in front of", "hint": "Před = in front of."}
      ]
    },
    {
      "id": "AJ4-15-03",
      "name": "Between, above, below, near",
      "difficulty": 2,
      "theory": "between = mezi (between the chairs). above = nad (above the door). below = pod/níže než. near = blízko (near the station).",
      "tasks": [
        {"id": "AJ4-15-03-001", "type": "choice", "question": "Co znamená 'between the chairs'?", "options": ["nad židlemi", "pod židlemi", "mezi židlemi", "vedle židlí", "za židlemi"], "answer": "mezi židlemi", "hint": "Between = mezi."},
        {"id": "AJ4-15-03-002", "type": "choice", "question": "Co znamená 'above the door'?", "options": ["pod dveřmi", "nad dveřmi", "za dveřmi", "vedle dveří", "před dveřmi"], "answer": "nad dveřmi", "hint": "Above = nad."},
        {"id": "AJ4-15-03-003", "type": "choice", "question": "Co znamená 'near the station'?", "options": ["na stanici", "pod stanicí", "za stanicí", "blízko stanice", "nad stanicí"], "answer": "blízko stanice", "hint": "Near = blízko."},
        {"id": "AJ4-15-03-004", "type": "choice", "question": "Jak řekneš anglicky 'mezi školou a parkem'?", "options": ["next to the school and park", "behind the school and park", "between the school and the park", "in front of the school and park", "above the school and park"], "answer": "between the school and the park", "hint": "Mezi = between."},
        {"id": "AJ4-15-03-005", "type": "choice", "question": "Jak řekneš anglicky 'nad oknem'?", "options": ["under the window", "on the window", "above the window", "next to the window", "behind the window"], "answer": "above the window", "hint": "Nad = above."},
        {"id": "AJ4-15-03-006", "type": "choice", "question": "Jak řekneš anglicky 'blízko školy'?", "options": ["in the school", "on the school", "behind the school", "near the school", "above the school"], "answer": "near the school", "hint": "Blízko = near."},
        {"id": "AJ4-15-03-007", "type": "choice", "question": "Doplň: 'The lamp is ___ the table.' (nad stolem)", "options": ["under", "on", "above", "next to", "behind"], "answer": "above", "hint": "Lampa visí NAD stolem."},
        {"id": "AJ4-15-03-008", "type": "choice", "question": "Doplň: 'I sit ___ Tom and Anna.' (mezi nimi)", "options": ["next to", "behind", "between", "in front of", "near"], "answer": "between", "hint": "Mezi = between."},
        {"id": "AJ4-15-03-009", "type": "choice", "question": "Doplň: 'The shop is ___ my house.' (blízko)", "options": ["above", "between", "near", "under", "behind"], "answer": "near", "hint": "Blízko = near."},
        {"id": "AJ4-15-03-010", "type": "choice", "question": "Doplň: 'The clock is ___ the blackboard.' (nad tabulí)", "options": ["under", "on", "above", "next to", "behind"], "answer": "above", "hint": "Hodiny jsou NAD tabulí."},
        {"id": "AJ4-15-03-011", "type": "choice", "question": "Co znamená 'The park is near the river'?", "options": ["Park je na řece.", "Park je pod řekou.", "Park je blízko řeky.", "Park je nad řekou.", "Park je za řekou."], "answer": "Park je blízko řeky.", "hint": "Near = blízko."},
        {"id": "AJ4-15-03-012", "type": "choice", "question": "Doplň: 'The bridge is ___ the river.' (nad řekou)", "options": ["under", "in", "above", "next to", "behind"], "answer": "above", "hint": "Most je NAD řekou."},
        {"id": "AJ4-15-03-013", "type": "choice", "question": "Doplň: 'Wednesday is ___ Tuesday and Thursday.'", "options": ["next to", "behind", "between", "above", "near"], "answer": "between", "hint": "Středa je MEZI úterým a čtvrtkem."},
        {"id": "AJ4-15-03-014", "type": "choice", "question": "Doplň: 'There is a park ___ our school.' (blízko)", "options": ["above", "between", "near", "under", "on"], "answer": "near", "hint": "Blízko = near."},
        {"id": "AJ4-15-03-015", "type": "choice", "question": "Doplň: 'The bird is ___ the roof.' (nad střechou)", "options": ["under", "in", "above", "behind", "between"], "answer": "above", "hint": "Pták je NAD střechou."},
        {"id": "AJ4-15-03-016", "type": "choice", "question": "Doplň: 'My house is ___ the school and the shop.'", "options": ["next to", "behind", "between", "above", "in front of"], "answer": "between", "hint": "Můj dům je MEZI školou a obchodem."},
