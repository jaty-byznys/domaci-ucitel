        {"id": "AJ4-15-04-016", "type": "choice", "question": "Kde je kniha? V tašce.", "options": ["on the bag", "under the bag", "in the bag", "behind the bag", "next to the bag"], "answer": "in the bag", "hint": "Uvnitř = in."},
        {"id": "AJ4-15-04-017", "type": "choice", "question": "Kde je koberec? Na podlaze.", "options": ["in the floor", "under the floor", "on the floor", "behind the floor", "above the floor"], "answer": "on the floor", "hint": "Na povrchu = on."}
      ]
