    {
      "id": "AJ4-15-04",
      "name": "Výběr správné předložky",
      "difficulty": 2,
      "theory": "Vyber předložku podle obrázku v hlavě: in = uvnitř, on = na povrchu, under = pod, next to = vedle, behind = za, in front of = před, between = mezi.",
      "tasks": [
        {"id": "AJ4-15-04-001", "type": "choice", "question": "Kde je mléko? V lednici.", "options": ["on the fridge", "under the fridge", "in the fridge", "behind the fridge", "next to the fridge"], "answer": "in the fridge", "hint": "Uvnitř = in."},
        {"id": "AJ4-15-04-002", "type": "choice", "question": "Kde je váza? Na stole.", "options": ["in the table", "under the table", "on the table", "behind the table", "between the table"], "answer": "on the table", "hint": "Na povrchu = on."},
        {"id": "AJ4-15-04-003", "type": "choice", "question": "Kde je míč? Pod postelí.", "options": ["in the bed", "on the bed", "under the bed", "behind the bed", "next to the bed"], "answer": "under the bed", "hint": "Pod = under."},
        {"id": "AJ4-15-04-004", "type": "choice", "question": "Kde je zahrada? Za domem.", "options": ["in front of the house", "next to the house", "behind the house", "in the house", "on the house"], "answer": "behind the house", "hint": "Za = behind."},
        {"id": "AJ4-15-04-005", "type": "choice", "question": "Kde parkuje auto? Před domem.", "options": ["behind the house", "next to the house", "in front of the house", "in the house", "on the house"], "answer": "in front of the house", "hint": "Před = in front of."},
        {"id": "AJ4-15-04-006", "type": "choice", "question": "Kde sedí Tom? Vedle Anny.", "options": ["behind Anna", "in front of Anna", "next to Anna", "in Anna", "under Anna"], "answer": "next to Anna", "hint": "Vedle = next to."},
