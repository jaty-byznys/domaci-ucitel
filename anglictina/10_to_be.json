{
  "id": "AJ4-10",
  "name": "Sloveso to be",
  "order": 9,
  "prerequisite": null,
  "skills": [
    {
      "id": "AJ4-10-01",
      "name": "To be – kladné tvary",
      "difficulty": 1,
      "theory": "I am (I'm), you are (you're), he is (he's), she is (she's), it is (it's), we are (we're), they are (they're).",
      "tasks": [
        {"id": "AJ4-10-01-001", "type": "choice", "question": "Doplň: 'I ___ a student.'", "options": ["is", "are", "am", "be", "has"], "answer": "am", "hint": "Já = I am."},
        {"id": "AJ4-10-01-002", "type": "choice", "question": "Doplň: 'She ___ my sister.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "She/he/it = is."},
        {"id": "AJ4-10-01-003", "type": "choice", "question": "Doplň: 'They ___ happy.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "They = are."},
        {"id": "AJ4-10-01-004", "type": "choice", "question": "Doplň: 'He ___ ten years old.'", "options": ["am", "are", "be", "is", "have"], "answer": "is", "hint": "He = is."},
        {"id": "AJ4-10-01-005", "type": "choice", "question": "Doplň: 'We ___ friends.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "We = are."},
        {"id": "AJ4-10-01-006", "type": "choice", "question": "Doplň: 'You ___ very tall.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "You = are (vždy)."},
        {"id": "AJ4-10-01-007", "type": "choice", "question": "Doplň: 'It ___ a dog.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "It = is."},
        {"id": "AJ4-10-01-008", "type": "choice", "question": "Doplň: 'I ___ from Prague.'", "options": ["is", "are", "am", "be", "has"], "answer": "am", "hint": "I = am."},
        {"id": "AJ4-10-01-009", "type": "choice", "question": "Doplň: 'The cat ___ black.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "The cat = it = is."},
        {"id": "AJ4-10-01-010", "type": "choice", "question": "Doplň: 'My parents ___ at home.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "My parents = they = are."},
        {"id": "AJ4-10-01-011", "type": "choice", "question": "Doplň: 'Tom ___ my brother.'", "options": ["am", "are", "be", "is", "have"], "answer": "is", "hint": "Tom = he = is."},
        {"id": "AJ4-10-01-012", "type": "choice", "question": "Doplň: 'The children ___ in the garden.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Children = they = are."},
        {"id": "AJ4-10-01-013", "type": "choice", "question": "Jak se zkráceně napíše 'I am'?", "options": ["I'am", "Iam", "I'm", "Im", "I,m"], "answer": "I'm", "hint": "Apostrof nahrazuje vynechané písmeno."},
        {"id": "AJ4-10-01-014", "type": "choice", "question": "Jak se zkráceně napíše 'she is'?", "options": ["shes", "she'is", "she's", "sheis", "she,s"], "answer": "she's", "hint": "She's = she is."},
        {"id": "AJ4-10-01-015", "type": "choice", "question": "Jak se zkráceně napíše 'they are'?", "options": ["their", "theyre", "they're", "they,re", "theyare"], "answer": "they're", "hint": "They're = they are. Pozor: their = jejich!"},
        {"id": "AJ4-10-01-016", "type": "choice", "question": "Doplň: 'My name ___ Anna.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "My name = it = is."},
        {"id": "AJ4-10-01-017", "type": "choice", "question": "Doplň: 'The books ___ on the table.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Books = množné číslo = are."}
      ]
    },
    {
      "id": "AJ4-10-02",
      "name": "To be – zápor",
      "difficulty": 1,
      "theory": "I am not (I'm not), you are not (you aren't), he is not (he isn't), she is not (she isn't), it is not (it isn't), we are not (we aren't), they are not (they aren't).",
      "tasks": [
        {"id": "AJ4-10-02-001", "type": "choice", "question": "Doplň: 'I ___ tired.' (zápor)", "options": ["am not", "is not", "are not", "not am", "don't"], "answer": "am not", "hint": "I am not = I'm not."},
        {"id": "AJ4-10-02-002", "type": "choice", "question": "Doplň: 'He ___ at school.' (zápor)", "options": ["am not", "are not", "isn't", "aren't", "don't"], "answer": "isn't", "hint": "He isn't = he is not."},
        {"id": "AJ4-10-02-003", "type": "choice", "question": "Doplň: 'They ___ from England.' (zápor)", "options": ["isn't", "am not", "aren't", "doesn't", "don't"], "answer": "aren't", "hint": "They aren't = they are not."},
        {"id": "AJ4-10-02-004", "type": "choice", "question": "Doplň: 'She ___ happy.' (zápor)", "options": ["aren't", "am not", "don't", "isn't", "not"], "answer": "isn't", "hint": "She isn't = she is not."},
        {"id": "AJ4-10-02-005", "type": "choice", "question": "Doplň: 'We ___ late.' (zápor)", "options": ["isn't", "am not", "don't", "aren't", "not"], "answer": "aren't", "hint": "We aren't = we are not."},
        {"id": "AJ4-10-02-006", "type": "choice", "question": "Doplň: 'It ___ cold today.' (zápor)", "options": ["aren't", "am not", "isn't", "don't", "not"], "answer": "isn't", "hint": "It isn't = it is not."},
        {"id": "AJ4-10-02-007", "type": "choice", "question": "Doplň: 'You ___ wrong.' (zápor)", "options": ["isn't", "am not", "don't", "aren't", "not"], "answer": "aren't", "hint": "You aren't = you are not."},
        {"id": "AJ4-10-02-008", "type": "choice", "question": "Jak zkráceně napíšeš 'is not'?", "options": ["isnt", "is'nt", "isn't", "is,not", "isnot"], "answer": "isn't", "hint": "Apostrof místo 'o'."},
        {"id": "AJ4-10-02-009", "type": "choice", "question": "Jak zkráceně napíšeš 'are not'?", "options": ["arnt", "are'nt", "aren't", "arenot", "ar'nt"], "answer": "aren't", "hint": "Apostrof místo 'o'."},
        {"id": "AJ4-10-02-010", "type": "choice", "question": "Doplň: 'The dog ___ big.' (zápor)", "options": ["aren't", "am not", "isn't", "don't", "doesn't"], "answer": "isn't", "hint": "The dog = it = isn't."},
        {"id": "AJ4-10-02-011", "type": "choice", "question": "Doplň: 'My friends ___ here.' (zápor)", "options": ["isn't", "am not", "aren't", "don't", "doesn't"], "answer": "aren't", "hint": "Friends = they = aren't."},
        {"id": "AJ4-10-02-012", "type": "choice", "question": "Vyber správnou zápornou větu:", "options": ["She not is tall.", "She is not tall.", "She no is tall.", "She don't tall.", "She isn't not tall."], "answer": "She is not tall.", "hint": "Podmět + is/are + not."},
        {"id": "AJ4-10-02-013", "type": "choice", "question": "Doplň: 'I ___ a teacher.' (zápor)", "options": ["isn't", "aren't", "am not", "don't", "not am"], "answer": "am not", "hint": "I am not. Pozor: neexistuje 'amn't'."},
        {"id": "AJ4-10-02-014", "type": "choice", "question": "Doplň: 'The weather ___ nice.' (zápor)", "options": ["aren't", "am not", "isn't", "don't", "not"], "answer": "isn't", "hint": "Weather = it = isn't."},
        {"id": "AJ4-10-02-015", "type": "choice", "question": "Vyber správnou větu:", "options": ["They no are hungry.", "They aren't hungry.", "They isn't hungry.", "They not hungry.", "They hungry aren't."], "answer": "They aren't hungry.", "hint": "They + aren't."},
        {"id": "AJ4-10-02-016", "type": "choice", "question": "Doplň: 'Tom and Lucy ___ at home.' (zápor)", "options": ["isn't", "am not", "aren't", "doesn't", "don't"], "answer": "aren't", "hint": "Tom and Lucy = they = aren't."},
        {"id": "AJ4-10-02-017", "type": "choice", "question": "Doplň: 'This ___ my bag.' (zápor)", "options": ["aren't", "am not", "don't", "isn't", "not"], "answer": "isn't", "hint": "This = it = isn't."}
      ]
    },
    {
      "id": "AJ4-10-03",
      "name": "To be – otázky",
      "difficulty": 2,
      "theory": "Am I...? Are you...? Is he/she/it...? Are we...? Are they...? Odpovědi: Yes, I am. / No, I'm not. Yes, he is. / No, he isn't.",
      "tasks": [
        {"id": "AJ4-10-03-001", "type": "choice", "question": "Jak se zeptáš 'Jsi šťastný?'?", "options": ["You are happy?", "Are you happy?", "Is you happy?", "Do you happy?", "Happy are you?"], "answer": "Are you happy?", "hint": "Are + you + přídavné jméno?"},
        {"id": "AJ4-10-03-002", "type": "choice", "question": "Jak se zeptáš 'Je ona doma?'?", "options": ["She is at home?", "Does she at home?", "Is she at home?", "Are she at home?", "Am she at home?"], "answer": "Is she at home?", "hint": "Is + she...?"},
        {"id": "AJ4-10-03-003", "type": "choice", "question": "Jak se zeptáš 'Jsou oni studenti?'?", "options": ["Is they students?", "They are students?", "Are they students?", "Do they students?", "Am they students?"], "answer": "Are they students?", "hint": "Are + they...?"},
        {"id": "AJ4-10-03-004", "type": "choice", "question": "Doplň otázku: '___ he your friend?'", "options": ["Am", "Are", "Do", "Is", "Has"], "answer": "Is", "hint": "He = is."},
        {"id": "AJ4-10-03-005", "type": "choice", "question": "Doplň otázku: '___ you from Czech Republic?'", "options": ["Is", "Am", "Do", "Are", "Has"], "answer": "Are", "hint": "You = are."},
        {"id": "AJ4-10-03-006", "type": "choice", "question": "Doplň otázku: '___ it a cat?'", "options": ["Am", "Are", "Do", "Is", "Has"], "answer": "Is", "hint": "It = is."},
        {"id": "AJ4-10-03-007", "type": "choice", "question": "Jak odpovíš kladně na 'Are you OK?'?", "options": ["Yes, I'm.", "Yes, I am.", "Yes, I are.", "Yes, am I.", "Yes, you are."], "answer": "Yes, I am.", "hint": "Krátká kladná odpověď: Yes, I am."},
        {"id": "AJ4-10-03-008", "type": "choice", "question": "Jak odpovíš záporně na 'Is he tall?'?", "options": ["No, he not.", "No, he aren't.", "No, he isn't.", "No, he don't.", "No, isn't he."], "answer": "No, he isn't.", "hint": "No + podmět + isn't/aren't."},
        {"id": "AJ4-10-03-009", "type": "choice", "question": "Jak odpovíš kladně na 'Is she a teacher?'?", "options": ["Yes, she are.", "Yes, she's.", "Yes, she is.", "Yes, is she.", "Yes, she am."], "answer": "Yes, she is.", "hint": "Yes, she is. (Ve zkrácené odpovědi nezkracujeme.)"},
        {"id": "AJ4-10-03-010", "type": "choice", "question": "Jak odpovíš záporně na 'Are they brothers?'?", "options": ["No, they isn't.", "No, they not.", "No, they aren't.", "No, aren't they.", "No, they don't."], "answer": "No, they aren't.", "hint": "They = aren't."},
        {"id": "AJ4-10-03-011", "type": "choice", "question": "Doplň otázku: '___ we late?'", "options": ["Is", "Am", "Do", "Are", "Has"], "answer": "Are", "hint": "We = are."},
        {"id": "AJ4-10-03-012", "type": "choice", "question": "Jak se zeptáš 'Jsem správně?'?", "options": ["I am right?", "Am I right?", "Is I right?", "Do I right?", "Right am I?"], "answer": "Am I right?", "hint": "Am + I...?"},
        {"id": "AJ4-10-03-013", "type": "choice", "question": "Doplň otázku: '___ the dog hungry?'", "options": ["Am", "Are", "Do", "Is", "Has"], "answer": "Is", "hint": "The dog = it = is."},
        {"id": "AJ4-10-03-014", "type": "choice", "question": "Jak odpovíš záporně na 'Are you tired?'?", "options": ["No, I amn't.", "No, I'm not.", "No, I aren't.", "No, not I am.", "No, I isn't."], "answer": "No, I'm not.", "hint": "I'm not. (Neexistuje amn't.)"},
        {"id": "AJ4-10-03-015", "type": "choice", "question": "Vyber správnou otázku:", "options": ["Are the windows open?", "Is the windows open?", "Do the windows open?", "The windows are open?", "Am the windows open?"], "answer": "Are the windows open?", "hint": "Windows = množné číslo = are."},
        {"id": "AJ4-10-03-016", "type": "choice", "question": "Doplň otázku: '___ your mum nice?'", "options": ["Am", "Are", "Do", "Is", "Has"], "answer": "Is", "hint": "Your mum = she = is."},
        {"id": "AJ4-10-03-017", "type": "choice", "question": "Jak odpovíš kladně na 'Are we friends?'?", "options": ["Yes, we is.", "Yes, we am.", "Yes, we are.", "Yes, are we.", "Yes, friends we."], "answer": "Yes, we are.", "hint": "Yes, we are."}
      ]
    },
    {
      "id": "AJ4-10-04",
      "name": "To be – výběr am/is/are",
      "difficulty": 1,
      "theory": "am = jen pro I. is = pro he, she, it (a jména v jednotném čísle). are = pro you, we, they (a množné číslo).",
      "tasks": [
        {"id": "AJ4-10-04-001", "type": "choice", "question": "Doplň: 'My dog ___ very cute.'", "options": ["am", "are", "be", "is", "have"], "answer": "is", "hint": "Dog = it = is."},
        {"id": "AJ4-10-04-002", "type": "choice", "question": "Doplň: 'The girls ___ in the classroom.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Girls = they = are."},
        {"id": "AJ4-10-04-003", "type": "choice", "question": "Doplň: 'I ___ hungry.'", "options": ["is", "are", "be", "am", "has"], "answer": "am", "hint": "I = am, vždy."},
        {"id": "AJ4-10-04-004", "type": "choice", "question": "Doplň: 'This pencil ___ red.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "Pencil = it = is."},
        {"id": "AJ4-10-04-005", "type": "choice", "question": "Doplň: 'You ___ my best friend.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "You = are."},
        {"id": "AJ4-10-04-006", "type": "choice", "question": "Doplň: 'The water ___ cold.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "Water = it = is."},
        {"id": "AJ4-10-04-007", "type": "choice", "question": "Doplň: 'Mum and dad ___ at work.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Mum and dad = they = are."},
        {"id": "AJ4-10-04-008", "type": "choice", "question": "Doplň: 'Peter ___ eleven.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "Peter = he = is."},
        {"id": "AJ4-10-04-009", "type": "choice", "question": "Doplň: 'The flowers ___ beautiful.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Flowers = množné číslo = are."},
        {"id": "AJ4-10-04-010", "type": "choice", "question": "Doplň: 'My teacher ___ nice.'", "options": ["am", "are", "be", "is", "have"], "answer": "is", "hint": "Teacher = he/she = is."},
        {"id": "AJ4-10-04-011", "type": "choice", "question": "Doplň: 'I ___ in class 4B.'", "options": ["is", "are", "be", "am", "has"], "answer": "am", "hint": "I = am."},
        {"id": "AJ4-10-04-012", "type": "choice", "question": "Doplň: 'The homework ___ easy.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "Homework = it = is."},
        {"id": "AJ4-10-04-013", "type": "choice", "question": "Doplň: 'We ___ in the park.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "We = are."},
        {"id": "AJ4-10-04-014", "type": "choice", "question": "Doplň: 'Anna and Tom ___ cousins.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Anna and Tom = they = are."},
        {"id": "AJ4-10-04-015", "type": "choice", "question": "Doplň: 'This ___ my favourite song.'", "options": ["am", "are", "be", "is", "has"], "answer": "is", "hint": "This = is."},
        {"id": "AJ4-10-04-016", "type": "choice", "question": "Doplň: 'The apples ___ on the table.'", "options": ["is", "am", "be", "are", "has"], "answer": "are", "hint": "Apples = they = are."}
      ]
    },
    {
      "id": "AJ4-10-05",
      "name": "To be – překlad vět",
      "difficulty": 2,
      "theory": "Překládej celé věty: Já jsem = I am. On je = He is. Oni jsou = They are.",
      "tasks": [
        {"id": "AJ4-10-05-001", "type": "choice", "question": "Přelož: 'Já jsem šťastný.'", "options": ["I is happy.", "I are happy.", "I am happy.", "I be happy.", "Me am happy."], "answer": "I am happy.", "hint": "I am = já jsem."},
        {"id": "AJ4-10-05-002", "type": "choice", "question": "Přelož: 'Ona je moje sestra.'", "options": ["She are my sister.", "She is my sister.", "She am my sister.", "Her is my sister.", "She be my sister."], "answer": "She is my sister.", "hint": "She is = ona je."},
        {"id": "AJ4-10-05-003", "type": "choice", "question": "Přelož: 'Oni jsou studenti.'", "options": ["They is students.", "Them are students.", "They are students.", "They am students.", "They be students."], "answer": "They are students.", "hint": "They are = oni jsou."},
        {"id": "AJ4-10-05-004", "type": "choice", "question": "Přelož: 'My jsme přátelé.'", "options": ["We is friends.", "We am friends.", "Us are friends.", "We are friends.", "We be friends."], "answer": "We are friends.", "hint": "We are = my jsme."},
        {"id": "AJ4-10-05-005", "type": "choice", "question": "Přelož: 'On není doma.'", "options": ["He aren't at home.", "He isn't at home.", "He not at home.", "He don't at home.", "Him isn't at home."], "answer": "He isn't at home.", "hint": "He isn't = on není."},
        {"id": "AJ4-10-05-006", "type": "choice", "question": "Přelož: 'Jsi unavený?'", "options": ["You are tired?", "Is you tired?", "Are you tired?", "Do you tired?", "Am you tired?"], "answer": "Are you tired?", "hint": "Are you...? = Jsi...?"},
        {"id": "AJ4-10-05-007", "type": "choice", "question": "Přelož: 'To je moje kočka.'", "options": ["This are my cat.", "That am my cat.", "It is my cat.", "Is my cat.", "My cat is."], "answer": "It is my cat.", "hint": "It is = to je."},
        {"id": "AJ4-10-05-008", "type": "choice", "question": "Přelož: 'Pes není velký.'", "options": ["The dog aren't big.", "The dog isn't big.", "The dog not big.", "The dog don't big.", "Dog no is big."], "answer": "The dog isn't big.", "hint": "The dog = it → isn't."},
        {"id": "AJ4-10-05-009", "type": "choice", "question": "Přelož: 'Je tvoje máma doma?'", "options": ["Are your mum at home?", "Is your mum at home?", "Does your mum at home?", "Your mum is at home?", "Am your mum at home?"], "answer": "Is your mum at home?", "hint": "Your mum = she → Is she...?"},
        {"id": "AJ4-10-05-010", "type": "choice", "question": "Přelož: 'Já nejsem hladový.'", "options": ["I isn't hungry.", "I aren't hungry.", "I'm not hungry.", "I not hungry.", "I don't hungry."], "answer": "I'm not hungry.", "hint": "I'm not = já nejsem."},
        {"id": "AJ4-10-05-011", "type": "choice", "question": "Přelož: 'Kde je tvůj bratr?'", "options": ["Where are your brother?", "Where is your brother?", "Where your brother is?", "Where does your brother?", "Where am your brother?"], "answer": "Where is your brother?", "hint": "Where is...? = Kde je...?"},
        {"id": "AJ4-10-05-012", "type": "choice", "question": "Přelož: 'Jsme ve škole.'", "options": ["We is at school.", "We am at school.", "We are at school.", "Us are at school.", "We be at school."], "answer": "We are at school.", "hint": "We are = my jsme."},
        {"id": "AJ4-10-05-013", "type": "choice", "question": "Přelož: 'Jak se jmenuješ?'", "options": ["How is your name?", "Who are you name?", "What is your name?", "What are your name?", "Where is your name?"], "answer": "What is your name?", "hint": "What is your name? = doslova 'Co je tvoje jméno?'"},
        {"id": "AJ4-10-05-014", "type": "choice", "question": "Přelož: 'Kolik ti je let?'", "options": ["How many are you?", "How old are you?", "How old is you?", "What age you are?", "How years are you?"], "answer": "How old are you?", "hint": "How old are you? = Jak starý jsi?"},
        {"id": "AJ4-10-05-015", "type": "choice", "question": "Přelož: 'Ty knihy jsou zajímavé.'", "options": ["The books is interesting.", "Books are interesting.", "The books are interesting.", "The books am interesting.", "This books is interesting."], "answer": "The books are interesting.", "hint": "Books = množné číslo = are."},
        {"id": "AJ4-10-05-016", "type": "choice", "question": "Přelož: 'Odkud jsi?'", "options": ["Where are you from?", "Where is you from?", "From where you are?", "Where do you from?", "Where you are from?"], "answer": "Where are you from?", "hint": "Where are you from?"}
      ]
    },
    {
      "id": "AJ4-10-06",
      "name": "To be – mix všeho",
      "difficulty": 2,
      "theory": "Procvičuj am/is/are v kladných, záporných i tázacích větách dohromady.",
      "tasks": [
        {"id": "AJ4-10-06-001", "type": "choice", "question": "Vyber správnou větu:", "options": ["She are a doctor.", "She is a doctor.", "She am a doctor.", "She be a doctor.", "Her is a doctor."], "answer": "She is a doctor.", "hint": "She = is."},
        {"id": "AJ4-10-06-002", "type": "choice", "question": "Vyber správnou větu:", "options": ["Are he your dad?", "Am he your dad?", "Is he your dad?", "Do he your dad?", "He is your dad?"], "answer": "Is he your dad?", "hint": "He = is → otázka: Is he...?"},
