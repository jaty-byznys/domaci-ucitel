        {"id": "AJ4-09-05-015", "type": "choice", "question": "Jak se správně píše neděle?", "options": ["Sundey", "Sonday", "Sunday", "Sundy", "Sunnday"], "answer": "Sunday", "hint": "Sun-day. Sun = slunce."},
        {"id": "AJ4-09-05-016", "type": "choice", "question": "Jak se správně píše září?", "options": ["Septembre", "Septamber", "September", "Setember", "Sepptember"], "answer": "September", "hint": "Septem-ber."},
        {"id": "AJ4-09-05-017", "type": "choice", "question": "Jak se správně píše červenec?", "options": ["Jully", "Juli", "July", "Juliy", "Julay"], "answer": "July", "hint": "Ju-ly. Krátké slovo, 4 písmena."}
      ]
    },
    {
