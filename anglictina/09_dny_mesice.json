        {"id": "AJ4-09-04-008", "type": "choice", "question": "Co znamená 'autumn'?", "options": ["jaro", "zima", "léto", "podzim", "vítr"], "answer": "podzim", "hint": "Padá listí."},
        {"id": "AJ4-09-04-009", "type": "choice", "question": "Jak se řekne anglicky 'jaro'?", "options": ["summer", "winter", "autumn", "spring", "fall"], "answer": "spring", "hint": "Začíná na Sp."},
