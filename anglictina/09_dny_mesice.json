    {
      "id": "AJ4-09-04",
      "name": "Roční období a měsíce",
      "difficulty": 2,
      "theory": "Spring (jaro) = March, April, May. Summer (léto) = June, July, August. Autumn/Fall (podzim) = September, October, November. Winter (zima) = December, January, February.",
      "tasks": [
