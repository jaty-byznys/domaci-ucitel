        {"id": "AJ4-09-05-002", "type": "choice", "question": "Který zápis je správně?", "options": ["february", "FEBRUARY", "February", "febRuary", "februAry"], "answer": "February", "hint": "Velké F na začátku."},
        {"id": "AJ4-09-05-003", "type": "choice", "question": "Jak se správně píše středa?", "options": ["Wendesday", "Wensday", "Wednesday", "Wednessday", "Wednsday"], "answer": "Wednesday", "hint": "Wed-nes-day. To 'd' uprostřed se nečte."},
