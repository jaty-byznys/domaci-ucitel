        {"id": "AJ4-09-01-010", "type": "choice", "question": "Jak se řekne anglicky 'středa'?", "options": ["Thursday", "Wednesday", "Tuesday", "Monday", "Friday"], "answer": "Wednesday", "hint": "Začíná na W."},
        {"id": "AJ4-09-01-011", "type": "choice", "question": "Jak se řekne anglicky 'neděle'?", "options": ["Saturday", "Monday", "Sunday", "Friday", "Tuesday"], "answer": "Sunday", "hint": "Začíná na S, končí na -day."},
        {"id": "AJ4-09-01-012", "type": "choice", "question": "Jak se řekne anglicky 'sobota'?", "options": ["Sunday", "Friday", "Saturday", "Thursday", "Monday"], "answer": "Saturday", "hint": "Začíná na S, má v sobě 'tur'."},
        {"id": "AJ4-09-01-013", "type": "choice", "question": "Jak se řekne anglicky 'úterý'?", "options": ["Thursday", "Tuesday", "Wednesday", "Monday", "Sunday"], "answer": "Tuesday", "hint": "Začíná na T, končí na -day."},
        {"id": "AJ4-09-01-014", "type": "choice", "question": "Jak se řekne anglicky 'čtvrtek'?", "options": ["Tuesday", "Friday", "Wednesday", "Thursday", "Saturday"], "answer": "Thursday", "hint": "Začíná na Th."},
        {"id": "AJ4-09-01-015", "type": "choice", "question": "Který den je v angličtině 'Saturday'?", "options": ["neděle", "pátek", "čtvrtek", "sobota", "středa"], "answer": "sobota", "hint": "Víkendový den, první z dvou."}
      ]
    },
    {
      "id": "AJ4-09-02",
      "name": "Měsíce – překlad",
      "difficulty": 1,
      "theory": "January = leden, February = únor, March = březen, April = duben, May = květen, June = červen, July = červenec, August = srpen, September = září, October = říjen, November = listopad, December = prosinec.",
      "tasks": [
        {"id": "AJ4-09-02-001", "type": "choice", "question": "Co znamená 'January'?", "options": ["únor", "leden", "březen", "prosinec", "duben"], "answer": "leden", "hint": "První měsíc v roce."},
        {"id": "AJ4-09-02-002", "type": "choice", "question": "Co znamená 'March'?", "options": ["duben", "únor", "květen", "březen", "leden"], "answer": "březen", "hint": "Třetí měsíc v roce."},
        {"id": "AJ4-09-02-003", "type": "choice", "question": "Co znamená 'June'?", "options": ["červenec", "květen", "červen", "srpen", "duben"], "answer": "červen", "hint": "Šestý měsíc, začíná léto."},
        {"id": "AJ4-09-02-004", "type": "choice", "question": "Co znamená 'September'?", "options": ["říjen", "srpen", "září", "listopad", "červenec"], "answer": "září", "hint": "Začíná škola."},
        {"id": "AJ4-09-02-005", "type": "choice", "question": "Co znamená 'December'?", "options": ["listopad", "leden", "říjen", "prosinec", "únor"], "answer": "prosinec", "hint": "Poslední měsíc v roce. Vánoce!"},
        {"id": "AJ4-09-02-006", "type": "choice", "question": "Co znamená 'February'?", "options": ["leden", "březen", "únor", "duben", "prosinec"], "answer": "únor", "hint": "Nejkratší měsíc."},
        {"id": "AJ4-09-02-007", "type": "choice", "question": "Co znamená 'August'?", "options": ["červenec", "září", "červen", "srpen", "říjen"], "answer": "srpen", "hint": "Osmý měsíc, prázdniny."},
        {"id": "AJ4-09-02-008", "type": "choice", "question": "Co znamená 'May'?", "options": ["duben", "červen", "březen", "květen", "červenec"], "answer": "květen", "hint": "Nejkratší název — jen 3 písmena."},
        {"id": "AJ4-09-02-009", "type": "choice", "question": "Co znamená 'November'?", "options": ["říjen", "prosinec", "září", "listopad", "srpen"], "answer": "listopad", "hint": "Předposlední měsíc v roce."},
        {"id": "AJ4-09-02-010", "type": "choice", "question": "Co znamená 'April'?", "options": ["březen", "květen", "duben", "červen", "únor"], "answer": "duben", "hint": "Apríl! Čtvrtý měsíc."},
        {"id": "AJ4-09-02-011", "type": "choice", "question": "Co znamená 'July'?", "options": ["červen", "srpen", "červenec", "květen", "září"], "answer": "červenec", "hint": "Sedmý měsíc, nejteplejší."},
        {"id": "AJ4-09-02-012", "type": "choice", "question": "Co znamená 'October'?", "options": ["září", "listopad", "srpen", "říjen", "prosinec"], "answer": "říjen", "hint": "Desátý měsíc, podzim."},
        {"id": "AJ4-09-02-013", "type": "choice", "question": "Jak se řekne anglicky 'leden'?", "options": ["February", "December", "January", "March", "June"], "answer": "January", "hint": "Začíná na J, je první."},
        {"id": "AJ4-09-02-014", "type": "choice", "question": "Jak se řekne anglicky 'září'?", "options": ["October", "November", "August", "September", "December"], "answer": "September", "hint": "Začíná na S, 9 písmen."},
        {"id": "AJ4-09-02-015", "type": "choice", "question": "Jak se řekne anglicky 'prosinec'?", "options": ["November", "January", "October", "December", "February"], "answer": "December", "hint": "Začíná na D, poslední měsíc."},
        {"id": "AJ4-09-02-016", "type": "choice", "question": "Jak se řekne anglicky 'květen'?", "options": ["March", "April", "June", "May", "July"], "answer": "May", "hint": "Nejkratší anglický název měsíce."},
        {"id": "AJ4-09-02-017", "type": "choice", "question": "Jak se řekne anglicky 'srpen'?", "options": ["July", "September", "June", "August", "October"], "answer": "August", "hint": "Začíná na A, 6 písmen."}
      ]
