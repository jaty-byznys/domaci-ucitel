        {"id": "AJ4-09-04-002", "type": "choice", "question": "Do kterého ročního období patří January?", "options": ["autumn", "spring", "summer", "winter", "fall"], "answer": "winter", "hint": "Leden = zima."},
        {"id": "AJ4-09-04-003", "type": "choice", "question": "Do kterého ročního období patří April?", "options": ["summer", "winter", "autumn", "spring", "fall"], "answer": "spring", "hint": "Duben = jaro."},
        {"id": "AJ4-09-04-004", "type": "choice", "question": "Do kterého ročního období patří October?", "options": ["spring", "summer", "autumn", "winter", "spring"], "answer": "autumn", "hint": "Říjen = podzim."},
        {"id": "AJ4-09-04-005", "type": "choice", "question": "Co znamená 'spring'?", "options": ["léto", "zima", "podzim", "jaro", "rok"], "answer": "jaro", "hint": "Kytky začínají kvést."},
        {"id": "AJ4-09-04-006", "type": "choice", "question": "Co znamená 'winter'?", "options": ["jaro", "podzim", "zima", "léto", "sníh"], "answer": "zima", "hint": "Sníh, mráz, Vánoce."},
