        {"id": "AJ4-09-03-007", "type": "choice", "question": "Který den následuje po Wednesday?", "options": ["Tuesday", "Friday", "Thursday", "Monday", "Saturday"], "answer": "Thursday", "hint": "Začíná na Th."},
        {"id": "AJ4-09-03-008", "type": "choice", "question": "Který měsíc je před May?", "options": ["June", "March", "April", "February", "July"], "answer": "April", "hint": "Čtvrtý měsíc."},
        {"id": "AJ4-09-03-009", "type": "choice", "question": "Který den je před Monday?", "options": ["Saturday", "Friday", "Sunday", "Tuesday", "Thursday"], "answer": "Sunday", "hint": "Poslední den týdne."},
        {"id": "AJ4-09-03-010", "type": "choice", "question": "Který měsíc následuje po June?", "options": ["August", "May", "July", "September", "April"], "answer": "July", "hint": "Sedmý měsíc."},
        {"id": "AJ4-09-03-011", "type": "choice", "question": "Který den následuje po Thursday?", "options": ["Wednesday", "Saturday", "Friday", "Monday", "Sunday"], "answer": "Friday", "hint": "Hurá, konec pracovního týdne!"},
