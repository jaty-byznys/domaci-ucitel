        {"id": "AJ4-09-04-015", "type": "choice", "question": "Jak se anglicky řekne 'podzim' dvěma způsoby?", "options": ["spring / winter", "autumn / fall", "summer / winter", "fall / spring", "autumn / spring"], "answer": "autumn / fall", "hint": "Oba výrazy znamenají totéž."},
        {"id": "AJ4-09-04-016", "type": "choice", "question": "Do kterého ročního období patří May?", "options": ["summer", "winter", "autumn", "spring", "fall"], "answer": "spring", "hint": "Květen = poslední jarní měsíc."},
        {"id": "AJ4-09-04-017", "type": "choice", "question": "Do kterého ročního období patří December?", "options": ["autumn", "spring", "summer", "winter", "fall"], "answer": "winter", "hint": "Prosinec = začátek zimy."}
      ]
