        {"id": "AJ4-09-03-002", "type": "choice", "question": "Který den je před Friday?", "options": ["Wednesday", "Saturday", "Thursday", "Tuesday", "Monday"], "answer": "Thursday", "hint": "Čtvrtý pracovní den."},
        {"id": "AJ4-09-03-003", "type": "choice", "question": "Který den následuje po Saturday?", "options": ["Monday", "Friday", "Sunday", "Tuesday", "Thursday"], "answer": "Sunday", "hint": "Druhý víkendový den."},
        {"id": "AJ4-09-03-004", "type": "choice", "question": "Který měsíc následuje po March?", "options": ["February", "May", "January", "April", "June"], "answer": "April", "hint": "Čtvrtý měsíc v roce."},
        {"id": "AJ4-09-03-005", "type": "choice", "question": "Který měsíc je před September?", "options": ["October", "July", "August", "November", "June"], "answer": "August", "hint": "Osmý měsíc, prázdniny."},
