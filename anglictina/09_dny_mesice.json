        {"id": "AJ4-09-03-014", "type": "choice", "question": "Kolikátý měsíc je October?", "options": ["9.", "11.", "8.", "10.", "12."], "answer": "10.", "hint": "Říjen = desátý."},
        {"id": "AJ4-09-03-015", "type": "choice", "question": "Kolikátý den v týdnu je Wednesday?", "options": ["2.", "4.", "3.", "5.", "1."], "answer": "3.", "hint": "Středa = třetí pracovní den."},
        {"id": "AJ4-09-03-016", "type": "choice", "question": "Který měsíc následuje po February?", "options": ["January", "April", "March", "May", "December"], "answer": "March", "hint": "Třetí měsíc v roce."},
        {"id": "AJ4-09-03-017", "type": "choice", "question": "Který den je před Wednesday?", "options": ["Thursday", "Monday", "Tuesday", "Friday", "Sunday"], "answer": "Tuesday", "hint": "Druhý pracovní den."}
      ]
