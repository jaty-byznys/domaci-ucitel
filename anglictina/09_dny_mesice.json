        {"id": "AJ4-09-05-006", "type": "choice", "question": "Jak se správně píše úterý?", "options": ["Tuseday", "Teusday", "Tuesday", "Tusday", "Tuesdy"], "answer": "Tuesday", "hint": "Tues-day."},
        {"id": "AJ4-09-05-007", "type": "choice", "question": "Jak se správně píše leden?", "options": ["Januari", "Janury", "January", "Januery", "Jannuary"], "answer": "January", "hint": "Janu-ary."},
        {"id": "AJ4-09-05-008", "type": "choice", "question": "Jak se správně píše říjen?", "options": ["Ocktober", "Oktober", "October", "Octobor", "Octobre"], "answer": "October", "hint": "Octo-ber. Jako 'octopus'."},
