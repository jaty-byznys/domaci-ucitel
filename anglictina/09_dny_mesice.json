    {
      "id": "AJ4-09-01",
      "name": "Dny v týdnu – překlad",
      "difficulty": 1,
      "theory": "Monday = pondělí, Tuesday = úterý, Wednesday = středa, Thursday = čtvrtek, Friday = pátek, Saturday = sobota, Sunday = neděle.",
      "tasks": [
        {"id": "AJ4-09-01-001", "type": "choice", "question": "Co znamená 'Monday'?", "options": ["úterý", "pondělí", "středa", "pátek", "neděle"], "answer": "pondělí", "hint": "Mon = první den pracovního týdne."},
        {"id": "AJ4-09-01-002", "type": "choice", "question": "Co znamená 'Friday'?", "options": ["čtvrtek", "sobota", "pátek", "středa", "pondělí"], "answer": "pátek", "hint": "Poslední pracovní den."},
        {"id": "AJ4-09-01-003", "type": "choice", "question": "Co znamená 'Wednesday'?", "options": ["čtvrtek", "úterý", "pondělí", "středa", "pátek"], "answer": "středa", "hint": "Je uprostřed pracovního týdne."},
        {"id": "AJ4-09-01-004", "type": "choice", "question": "Co znamená 'Sunday'?", "options": ["sobota", "pondělí", "neděle", "pátek", "čtvrtek"], "answer": "neděle", "hint": "Sun = slunce. Den odpočinku."},
        {"id": "AJ4-09-01-005", "type": "choice", "question": "Co znamená 'Tuesday'?", "options": ["pondělí", "středa", "úterý", "čtvrtek", "sobota"], "answer": "úterý", "hint": "Druhý den v týdnu."},
        {"id": "AJ4-09-01-006", "type": "choice", "question": "Co znamená 'Thursday'?", "options": ["úterý", "pátek", "středa", "čtvrtek", "sobota"], "answer": "čtvrtek", "hint": "Čtvrtý den pracovního týdne."},
        {"id": "AJ4-09-01-007", "type": "choice", "question": "Co znamená 'Saturday'?", "options": ["neděle", "pátek", "sobota", "čtvrtek", "pondělí"], "answer": "sobota", "hint": "První den víkendu."},
        {"id": "AJ4-09-01-008", "type": "choice", "question": "Jak se řekne anglicky 'pondělí'?", "options": ["Tuesday", "Sunday", "Monday", "Friday", "Thursday"], "answer": "Monday", "hint": "Začíná na M."},
