        {"id": "AJ4-08-03-004", "type": "choice", "question": "Co znamená 'There is a sofa in the living room'?", "options": ["V ložnici je pohovka.", "V kuchyni je pohovka.", "V obýváku je pohovka.", "V koupelně je pohovka.", "V zahradě je pohovka."], "answer": "V obýváku je pohovka.", "hint": "Living room = obývací pokoj."},
