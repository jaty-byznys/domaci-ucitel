{
  "id": "AJ4-03",
  "name": "Zvířata",
  "order": 2,
  "prerequisite": null,
  "skills": [
    {
      "id": "AJ4-03-01",
      "name": "Domácí zvířata — překlad",
      "difficulty": 1,
      "theory": "Domácí zvířata: cat = kočka, dog = pes, horse = kůň, cow = kráva, pig = prase, chicken = kuře/slepice, rabbit = králík, hamster = křeček, sheep = ovce, goat = koza, duck = kachna, guinea pig = morče.",
      "tasks": [
        {"id": "AJ4-03-01-001", "type": "choice", "question": "Co znamená 'cat'?", "options": ["pes", "kočka", "králík", "křeček", "koza"], "answer": "kočka", "hint": "Říká 'mňau'."},
        {"id": "AJ4-03-01-002", "type": "choice", "question": "Co znamená 'dog'?", "options": ["kočka", "kůň", "pes", "prase", "ovce"], "answer": "pes", "hint": "Říká 'haf'."},
        {"id": "AJ4-03-01-003", "type": "choice", "question": "Co znamená 'horse'?", "options": ["kráva", "kůň", "koza", "ovce", "pes"], "answer": "kůň", "hint": "Dá se na něm jezdit."},
        {"id": "AJ4-03-01-004", "type": "choice", "question": "Co znamená 'cow'?", "options": ["koza", "ovce", "kráva", "kůň", "prase"], "answer": "kráva", "hint": "Dává mléko."},
        {"id": "AJ4-03-01-005", "type": "choice", "question": "Co znamená 'pig'?", "options": ["pes", "kráva", "koza", "prase", "kachna"], "answer": "prase", "hint": "Říká 'chro chro'."},
        {"id": "AJ4-03-01-006", "type": "choice", "question": "Co znamená 'chicken'?", "options": ["kachna", "králík", "kuře", "holub", "prase"], "answer": "kuře", "hint": "Snáší vejce."},
        {"id": "AJ4-03-01-007", "type": "choice", "question": "Co znamená 'rabbit'?", "options": ["křeček", "králík", "morče", "myš", "kočka"], "answer": "králík", "hint": "Má dlouhé uši a skáče."},
        {"id": "AJ4-03-01-008", "type": "choice", "question": "Co znamená 'hamster'?", "options": ["králík", "morče", "křeček", "myš", "kočka"], "answer": "křeček", "hint": "Malý hlodavec, běhá v kolečku."},
        {"id": "AJ4-03-01-009", "type": "choice", "question": "Co znamená 'sheep'?", "options": ["koza", "ovce", "kráva", "kůň", "prase"], "answer": "ovce", "hint": "Má vlnu."},
        {"id": "AJ4-03-01-010", "type": "choice", "question": "Co znamená 'duck'?", "options": ["slepice", "husa", "kachna", "holub", "kuře"], "answer": "kachna", "hint": "Plave na vodě a říká 'kvák'."},
        {"id": "AJ4-03-01-011", "type": "choice", "question": "Co znamená 'goat'?", "options": ["ovce", "kráva", "koza", "kůň", "prase"], "answer": "koza", "hint": "Má rohy a rouho."},
        {"id": "AJ4-03-01-012", "type": "choice", "question": "Co znamená 'guinea pig'?", "options": ["prase", "křeček", "králík", "morče", "myš"], "answer": "morče", "hint": "Není to prase! Je to malý mazlíček."},
        {"id": "AJ4-03-01-013", "type": "choice", "question": "Jak se řekne anglicky 'kočka'?", "options": ["dog", "cat", "cow", "bat", "rat"], "answer": "cat", "hint": "Tři písmenka, začíná na C."},
        {"id": "AJ4-03-01-014", "type": "choice", "question": "Jak se řekne anglicky 'pes'?", "options": ["cat", "pig", "dog", "duck", "goat"], "answer": "dog", "hint": "Tři písmenka, začíná na D."},
        {"id": "AJ4-03-01-015", "type": "choice", "question": "Jak se řekne anglicky 'kůň'?", "options": ["cow", "goat", "sheep", "horse", "pig"], "answer": "horse", "hint": "Začíná na H."},
        {"id": "AJ4-03-01-016", "type": "choice", "question": "Jak se řekne anglicky 'králík'?", "options": ["hamster", "rabbit", "guinea pig", "mouse", "rat"], "answer": "rabbit", "hint": "Začíná na R."},
        {"id": "AJ4-03-01-017", "type": "choice", "question": "Jak se řekne anglicky 'ovce'?", "options": ["goat", "cow", "sheep", "pig", "horse"], "answer": "sheep", "hint": "Začíná na SH."}
      ]
    },
    {
      "id": "AJ4-03-02",
      "name": "Divoká zvířata — překlad",
      "difficulty": 1,
      "theory": "Divoká zvířata: lion = lev, tiger = tygr, elephant = slon, monkey = opice, bear = medvěd, snake = had, fish = ryba, bird = pták, wolf = vlk, fox = liška, frog = žába, mouse = myš, crocodile = krokodýl, parrot = papoušek, penguin = tučňák.",
      "tasks": [
        {"id": "AJ4-03-02-001", "type": "choice", "question": "Co znamená 'lion'?", "options": ["tygr", "lev", "medvěd", "vlk", "liška"], "answer": "lev", "hint": "Král zvířat."},
        {"id": "AJ4-03-02-002", "type": "choice", "question": "Co znamená 'tiger'?", "options": ["lev", "tygr", "leopard", "gepard", "vlk"], "answer": "tygr", "hint": "Pruhovaná kočkovitá šelma."},
        {"id": "AJ4-03-02-003", "type": "choice", "question": "Co znamená 'elephant'?", "options": ["nosorožec", "hroch", "slon", "žirafa", "krokodýl"], "answer": "slon", "hint": "Největší suchozemské zvíře."},
        {"id": "AJ4-03-02-004", "type": "choice", "question": "Co znamená 'monkey'?", "options": ["opice", "medvěd", "liška", "papoušek", "had"], "answer": "opice", "hint": "Leze po stromech a jí banány."},
        {"id": "AJ4-03-02-005", "type": "choice", "question": "Co znamená 'bear'?", "options": ["vlk", "liška", "had", "medvěd", "tygr"], "answer": "medvěd", "hint": "Velké zvíře, má rád med."},
        {"id": "AJ4-03-02-006", "type": "choice", "question": "Co znamená 'snake'?", "options": ["žába", "ryba", "had", "krokodýl", "ještěrka"], "answer": "had", "hint": "Plazí se po zemi, nemá nohy."},
        {"id": "AJ4-03-02-007", "type": "choice", "question": "Co znamená 'fish'?", "options": ["pták", "ryba", "žába", "had", "kachna"], "answer": "ryba", "hint": "Plave ve vodě."},
        {"id": "AJ4-03-02-008", "type": "choice", "question": "Co znamená 'bird'?", "options": ["ryba", "motýl", "pták", "včela", "papoušek"], "answer": "pták", "hint": "Má křídla a létá."},
        {"id": "AJ4-03-02-009", "type": "choice", "question": "Co znamená 'wolf'?", "options": ["liška", "vlk", "medvěd", "pes", "lev"], "answer": "vlk", "hint": "Vyje na měsíc."},
        {"id": "AJ4-03-02-010", "type": "choice", "question": "Co znamená 'fox'?", "options": ["vlk", "pes", "liška", "kočka", "medvěd"], "answer": "liška", "hint": "Chytrá, rezavá, žije v lese."},
        {"id": "AJ4-03-02-011", "type": "choice", "question": "Co znamená 'frog'?", "options": ["had", "ryba", "ještěrka", "žába", "krokodýl"], "answer": "žába", "hint": "Skáče a žije u vody."},
        {"id": "AJ4-03-02-012", "type": "choice", "question": "Co znamená 'mouse'?", "options": ["křeček", "morče", "myš", "králík", "krysa"], "answer": "myš", "hint": "Malý hlodavec, kočka ji honí."},
        {"id": "AJ4-03-02-013", "type": "choice", "question": "Co znamená 'penguin'?", "options": ["papoušek", "tučňák", "pštros", "orel", "holub"], "answer": "tučňák", "hint": "Černobílý pták, neumí létat, žije na ledu."},
        {"id": "AJ4-03-02-014", "type": "choice", "question": "Jak se řekne anglicky 'lev'?", "options": ["tiger", "bear", "lion", "wolf", "fox"], "answer": "lion", "hint": "Začíná na L."},
        {"id": "AJ4-03-02-015", "type": "choice", "question": "Jak se řekne anglicky 'slon'?", "options": ["crocodile", "elephant", "hippo", "rhino", "giraffe"], "answer": "elephant", "hint": "Začíná na E, má chobot."},
        {"id": "AJ4-03-02-016", "type": "choice", "question": "Jak se řekne anglicky 'medvěd'?", "options": ["bird", "bear", "boar", "bee", "bat"], "answer": "bear", "hint": "Začíná na B, 4 písmenka."},
        {"id": "AJ4-03-02-017", "type": "choice", "question": "Jak se řekne anglicky 'had'?", "options": ["snail", "snake", "shark", "spider", "seal"], "answer": "snake", "hint": "Začíná na SN."},
        {"id": "AJ4-03-02-018", "type": "choice", "question": "Jak se řekne anglicky 'žába'?", "options": ["fish", "fly", "fox", "frog", "flamingo"], "answer": "frog", "hint": "Začíná na FR."}
      ]
    },
    {
      "id": "AJ4-03-03",
      "name": "Co zvířata umí — can / can't",
      "difficulty": 2,
      "theory": "Řekneme, co zvířata umí: A bird can fly. A fish can swim. A snake can't walk. A penguin can't fly.",
      "tasks": [
        {"id": "AJ4-03-03-001", "type": "choice", "question": "A fish can ___.", "options": ["fly", "run", "swim", "climb", "sing"], "answer": "swim", "hint": "Ryba plave."},
        {"id": "AJ4-03-03-002", "type": "choice", "question": "A bird can ___.", "options": ["swim", "fly", "bark", "crawl", "dig"], "answer": "fly", "hint": "Ptáci létají."},
        {"id": "AJ4-03-03-003", "type": "choice", "question": "A dog can ___.", "options": ["fly", "swim", "run", "climb trees", "sing"], "answer": "run", "hint": "Psi běhají."},
        {"id": "AJ4-03-03-004", "type": "choice", "question": "A penguin can't ___.", "options": ["swim", "walk", "eat", "fly", "stand"], "answer": "fly", "hint": "Tučňák neumí létat."},
        {"id": "AJ4-03-03-005", "type": "choice", "question": "A frog can ___.", "options": ["fly", "bark", "sing", "jump", "climb"], "answer": "jump", "hint": "Žáby skáčou."},
        {"id": "AJ4-03-03-006", "type": "choice", "question": "A snake can't ___.", "options": ["crawl", "bite", "hiss", "walk", "swim"], "answer": "walk", "hint": "Had nemá nohy."},
        {"id": "AJ4-03-03-007", "type": "choice", "question": "A monkey can ___.", "options": ["fly", "swim in the sea", "climb trees", "bark", "moo"], "answer": "climb trees", "hint": "Opice lezou po stromech."},
        {"id": "AJ4-03-03-008", "type": "choice", "question": "A cat can't ___.", "options": ["climb", "jump", "run", "fly", "meow"], "answer": "fly", "hint": "Kočky nelétají."},
        {"id": "AJ4-03-03-009", "type": "choice", "question": "Co znamená 'A horse can run fast'?", "options": ["Kůň umí plavat rychle.", "Kůň umí létat rychle.", "Kůň umí běhat rychle.", "Kůň umí skákat rychle.", "Kůň umí kopat rychle."], "answer": "Kůň umí běhat rychle.", "hint": "Run = běhat, fast = rychle."},
        {"id": "AJ4-03-03-010", "type": "choice", "question": "Co znamená 'An elephant can't jump'?", "options": ["Slon umí skákat.", "Slon neumí plavat.", "Slon neumí skákat.", "Slon neumí běhat.", "Slon umí běhat."], "answer": "Slon neumí skákat.", "hint": "Can't = neumí."},
        {"id": "AJ4-03-03-011", "type": "choice", "question": "Které zvíře CAN'T swim?", "options": ["duck", "fish", "frog", "hamster", "dog"], "answer": "hamster", "hint": "Křečci typicky neplavou."},
        {"id": "AJ4-03-03-012", "type": "choice", "question": "Které zvíře CAN fly?", "options": ["penguin", "chicken", "parrot", "rabbit", "frog"], "answer": "parrot", "hint": "Papoušek létá."},
        {"id": "AJ4-03-03-013", "type": "choice", "question": "Doplň: 'Can a cat climb?' — 'Yes, it ___.'", "options": ["does", "is", "has", "can", "do"], "answer": "can", "hint": "Can → Yes, it can."},
        {"id": "AJ4-03-03-014", "type": "choice", "question": "Doplň: 'Can a fish walk?' — 'No, it ___.'", "options": ["don't", "isn't", "can't", "doesn't", "hasn't"], "answer": "can't", "hint": "Can → No, it can't."},
        {"id": "AJ4-03-03-015", "type": "choice", "question": "Co znamená 'swim'?", "options": ["létat", "běhat", "skákat", "plavat", "lézt"], "answer": "plavat", "hint": "Ryby a kachny to umí."}
      ]
    },
    {
      "id": "AJ4-03-04",
      "name": "Popis zvířat",
      "difficulty": 2,
      "theory": "Popíšeme zvíře: It is big/small. It has got four legs. It is brown. It lives in the forest/sea/farm.",
      "tasks": [
        {"id": "AJ4-03-04-001", "type": "choice", "question": "It is very big. It is grey. It has got a long nose (trunk). What is it?", "options": ["bear", "hippo", "elephant", "rhino", "whale"], "answer": "elephant", "hint": "Trunk = chobot."},
        {"id": "AJ4-03-04-002", "type": "choice", "question": "It is small. It is brown or white. It has got long ears. What is it?", "options": ["hamster", "mouse", "cat", "rabbit", "guinea pig"], "answer": "rabbit", "hint": "Dlouhé uši + skáče."},
        {"id": "AJ4-03-04-003", "type": "choice", "question": "It lives on a farm. It gives us milk. What is it?", "options": ["horse", "pig", "sheep", "cow", "goat"], "answer": "cow", "hint": "Dává mléko a žije na farmě."},
        {"id": "AJ4-03-04-004", "type": "choice", "question": "It is orange and black. It is a big cat. What is it?", "options": ["lion", "leopard", "tiger", "cheetah", "panther"], "answer": "tiger", "hint": "Oranžový s černými pruhy."},
        {"id": "AJ4-03-04-005", "type": "choice", "question": "It lives in water. It can swim but can't walk. What is it?", "options": ["frog", "duck", "fish", "snake", "penguin"], "answer": "fish", "hint": "Žije celý život ve vodě."},
        {"id": "AJ4-03-04-006", "type": "choice", "question": "It is small and green. It lives near water. It can jump. What is it?", "options": ["snake", "fish", "turtle", "frog", "lizard"], "answer": "frog", "hint": "Malá, zelená, skáče u vody."},
        {"id": "AJ4-03-04-007", "type": "choice", "question": "It is black and white. It lives in cold places. It can swim but can't fly. What is it?", "options": ["panda", "penguin", "zebra", "seagull", "swan"], "answer": "penguin", "hint": "Černobílý, studené kraje, nelétá."},
        {"id": "AJ4-03-04-008", "type": "choice", "question": "It has got no legs. It can be very long. It lives in grass. What is it?", "options": ["worm", "caterpillar", "snake", "snail", "fish"], "answer": "snake", "hint": "Žádné nohy, dlouhý, plazí se."},
        {"id": "AJ4-03-04-009", "type": "choice", "question": "It is yellow. It lives on a farm. It says 'quack'. What is it?", "options": ["chicken", "goose", "parrot", "duck", "canary"], "answer": "duck", "hint": "Quack = kvák."},
        {"id": "AJ4-03-04-010", "type": "choice", "question": "It is big and brown. It lives in the forest. It likes honey. What is it?", "options": ["wolf", "deer", "bear", "fox", "moose"], "answer": "bear", "hint": "Velký, hnědý, med."},
        {"id": "AJ4-03-04-011", "type": "choice", "question": "Co znamená 'It has got four legs'?", "options": ["Má čtyři oči.", "Má čtyři nohy.", "Má čtyři uši.", "Má čtyři zuby.", "Má čtyři křídla."], "answer": "Má čtyři nohy.", "hint": "Legs = nohy."},
        {"id": "AJ4-03-04-012", "type": "choice", "question": "Co znamená 'It has got a long tail'?", "options": ["Má dlouhý krk.", "Má dlouhé uši.", "Má dlouhý ocas.", "Má dlouhé nohy.", "Má dlouhý nos."], "answer": "Má dlouhý ocas.", "hint": "Tail = ocas."},
        {"id": "AJ4-03-04-013", "type": "choice", "question": "Co znamená 'wings'?", "options": ["nohy", "oči", "uši", "křídla", "zuby"], "answer": "křídla", "hint": "Ptáci mají wings."},
        {"id": "AJ4-03-04-014", "type": "choice", "question": "Co znamená 'fur'?", "options": ["peří", "šupiny", "srst", "kůže", "vlna"], "answer": "srst", "hint": "Kočky a psi mají fur."},
        {"id": "AJ4-03-04-015", "type": "choice", "question": "Jak řekneš 'Má velké oči'?", "options": ["It has got big eyes.", "It has got big ears.", "It has got big legs.", "It has got big teeth.", "It is got big eyes."], "answer": "It has got big eyes.", "hint": "Eyes = oči."}
      ]
    },
    {
      "id": "AJ4-03-05",
      "name": "Zvířata — kde žijí",
      "difficulty": 2,
      "theory": "Kde zvířata žijí: farm = farma, forest = les, sea/ocean = moře, river = řeka, jungle = džungle, zoo = zoo, house/home = dům.",
      "tasks": [
        {"id": "AJ4-03-05-001", "type": "choice", "question": "Where does a cow live?", "options": ["in the forest", "in the sea", "on a farm", "in the jungle", "in the zoo"], "answer": "on a farm", "hint": "Krávy žijí na farmě."},
        {"id": "AJ4-03-05-002", "type": "choice", "question": "Where does a fish live?", "options": ["on a farm", "in the forest", "in a house", "in water", "in a tree"], "answer": "in water", "hint": "Ryby žijí ve vodě."},
        {"id": "AJ4-03-05-003", "type": "choice", "question": "Where does a wolf live?", "options": ["on a farm", "in a house", "in the forest", "in the sea", "in a zoo"], "answer": "in the forest", "hint": "Vlci žijí v lese."},
        {"id": "AJ4-03-05-004", "type": "choice", "question": "Where does a monkey live?", "options": ["on a farm", "in the sea", "in the jungle", "in the river", "in the Arctic"], "answer": "in the jungle", "hint": "Opice žijí v džungli."},
        {"id": "AJ4-03-05-005", "type": "choice", "question": "Where does a cat live?", "options": ["in the jungle", "in the forest", "in a house", "on a farm", "in the sea"], "answer": "in a house", "hint": "Domácí kočka žije v domě."},
        {"id": "AJ4-03-05-006", "type": "choice", "question": "Co znamená 'farm'?", "options": ["les", "farma", "zoo", "zahrada", "park"], "answer": "farma", "hint": "Místo kde chovají zvířata a pěstují plodiny."},
        {"id": "AJ4-03-05-007", "type": "choice", "question": "Co znamená 'forest'?", "options": ["pole", "louka", "les", "hora", "řeka"], "answer": "les", "hint": "Hodně stromů pohromadě."},
        {"id": "AJ4-03-05-008", "type": "choice", "question": "Co znamená 'jungle'?", "options": ["poušť", "les", "džungle", "hora", "ostrov"], "answer": "džungle", "hint": "Tropický prales."},
        {"id": "AJ4-03-05-009", "type": "choice", "question": "Které zvíře žije 'in the sea'?", "options": ["rabbit", "bear", "shark", "fox", "frog"], "answer": "shark", "hint": "Shark = žralok, žije v moři."},
        {"id": "AJ4-03-05-010", "type": "choice", "question": "Které zvíře žije 'on a farm'?", "options": ["lion", "monkey", "shark", "pig", "penguin"], "answer": "pig", "hint": "Prasata žijí na farmě."},
        {"id": "AJ4-03-05-011", "type": "choice", "question": "Které zvíře žije 'in the forest' v ČR?", "options": ["elephant", "monkey", "penguin", "deer", "parrot"], "answer": "deer", "hint": "Deer = jelen — žije v českých lesích."},
        {"id": "AJ4-03-05-012", "type": "choice", "question": "Co znamená 'wild animals'?", "options": ["domácí zvířata", "zvířata v zoo", "divoká zvířata", "mazlíčci", "hospodářská zvířata"], "answer": "divoká zvířata", "hint": "Wild = divoký."},
        {"id": "AJ4-03-05-013", "type": "choice", "question": "Co znamená 'pet'?", "options": ["divoké zvíře", "pták", "mazlíček", "zvíře v zoo", "hmyz"], "answer": "mazlíček", "hint": "Domácí mazlíček — pes, kočka, křeček..."}
      ]
    },
    {
      "id": "AJ4-03-06",
      "name": "Zvířata — mix a opakování",
      "difficulty": 2,
      "theory": "Dáme všechno dohromady!",
      "tasks": [
        {"id": "AJ4-03-06-001", "type": "choice", "question": "Které slovo NEPATŘÍ mezi zvířata?", "options": ["cat", "dog", "table", "bird", "fish"], "answer": "table", "hint": "Table = stůl."},
        {"id": "AJ4-03-06-002", "type": "choice", "question": "Které zvíře NEPATŘÍ na farmu?", "options": ["cow", "pig", "chicken", "lion", "sheep"], "answer": "lion", "hint": "Lev žije v Africe, ne na farmě."},
        {"id": "AJ4-03-06-003", "type": "choice", "question": "Kolik nohou má 'spider'?", "options": ["four", "six", "eight", "ten", "two"], "answer": "eight", "hint": "Spider = pavouk — 8 noh."},
