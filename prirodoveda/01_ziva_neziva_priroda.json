{
  "id": "PR4-01",
  "name": "Živá a neživá příroda",
  "order": 0,
  "prerequisite": null,
  "skills": [
    {
      "id": "PR4-01-01",
      "name": "Živá a neživá příroda — základy",
      "difficulty": 1,
      "theory": "Živá příroda: rostliny, živočichové, houby. Neživá: voda, vzduch, horniny, půda, slunce.",
      "tasks": [
        {"id":"PR4-01-01-001","type":"choice","question":"Co patří do živé přírody?","options":["písek","kámen","vzduch","voda","strom"],"answer":"strom","hint":"Živé organismy rostou, dýchají, rozmnožují se."},
        {"id":"PR4-01-01-002","type":"choice","question":"Co patří do neživé přírody?","options":["rostlina","hornina","ryba","kočka","houba"],"answer":"hornina","hint":"Hornina neroste, nedýchá, nerozmnožuje se."},
        {"id":"PR4-01-01-003","type":"choice","question":"Co je živý organismus?","options":["oblak","řeka","led","strom","skála"],"answer":"strom","hint":"Strom roste, dýchá, rozmnožuje se."},
        {"id":"PR4-01-01-004","type":"choice","question":"Která vlastnost je typická pro živé organismy?","options":["tavení","krystalizace","rozmnožování","magnetismus","vodivost"],"answer":"rozmnožování","hint":"Živé organismy vytvářejí potomky."},
        {"id":"PR4-01-01-005","type":"choice","question":"Do které skupiny patří houby?","options":["neživá příroda","rostliny","živočichové","houby (vlastní skupina)","nerosty"],"answer":"houby (vlastní skupina)","hint":"Houby nejsou ani rostliny, ani živočichové."},
        {"id":"PR4-01-01-006","type":"choice","question":"Co NEPATŘÍ do živé přírody?","options":["mravenec","sedmikráska","hřib","žába","písek"],"answer":"písek","hint":"Písek je neživá příroda."},
        {"id":"PR4-01-01-007","type":"choice","question":"Na jaké tři skupiny dělíme živou přírodu?","options":["voda, vzduch, půda","rostliny, živočichové, houby","kameny, písky, hlíny","ryby, ptáci, savci","stromy, keře, byliny"],"answer":"rostliny, živočichové, houby","hint":"Tři hlavní skupiny organismů."},
        {"id":"PR4-01-01-008","type":"choice","question":"Co mají společného strom a kočka?","options":["oba létají","oba jsou neživé","oba jsou živé organismy","oba žijí ve vodě","oba jsou rostliny"],"answer":"oba jsou živé organismy","hint":"Oba rostou, dýchají, rozmnožují se."},
        {"id":"PR4-01-01-009","type":"choice","question":"Proč je voda neživá?","options":["je studená","neroste a nerozmnožuje se","je průhledná","teče","je mokrá"],"answer":"neroste a nerozmnožuje se","hint":"Voda nemá vlastnosti živého organismu."},
        {"id":"PR4-01-01-010","type":"choice","question":"Který z těchto výroků je PRAVDIVÝ?","options":["kameny dýchají","slunce je živý organismus","rostliny se rozmnožují","vzduch je živý","oheň je živý organismus"],"answer":"rostliny se rozmnožují","hint":"Rozmnožování je znak živých organismů."}
      ]
    },
    {
      "id": "PR4-01-02",
      "name": "Vlastnosti živých organismů",
      "difficulty": 1,
      "theory": "Živé organismy: dýchají, přijímají potravu, rostou, rozmnožují se, reagují na podněty, vylučují odpadní látky.",
      "tasks": [
        {"id":"PR4-01-02-001","type":"choice","question":"Co živé organismy potřebují k životu?","options":["jen vodu","jen světlo","potravu, vodu a vzduch","jen teplo","jen půdu"],"answer":"potravu, vodu a vzduch","hint":"Základní potřeby: jíst, pít, dýchat."},
        {"id":"PR4-01-02-002","type":"choice","question":"Co NEDĚLAJÍ neživé věci?","options":["existují","zabírají prostor","rostou samy od sebe","mají tvar","mají barvu"],"answer":"rostou samy od sebe","hint":"Kámen neroste — živé organismy ano."},
        {"id":"PR4-01-02-003","type":"choice","question":"Který organismus NEDÝCHÁ?","options":["strom","ryba","člověk","kámen","pes"],"answer":"kámen","hint":"Dýchání je vlastnost živých organismů."},
        {"id":"PR4-01-02-004","type":"choice","question":"Co znamená, že organismus reaguje na podněty?","options":["je hlučný","odpovídá na změny v okolí","je velký","má barvu","je tvrdý"],"answer":"odpovídá na změny v okolí","hint":"Třeba slunečnice se otáčí za sluncem."},
        {"id":"PR4-01-02-005","type":"choice","question":"Jak se říká schopnosti organismu vytvořit potomky?","options":["dýchání","růst","rozmnožování","trávení","pohyb"],"answer":"rozmnožování","hint":"Potomci = nová generace."},
        {"id":"PR4-01-02-006","type":"choice","question":"Co NENÍ vlastnost živého organismu?","options":["dýchání","růst","rozmnožování","tavení","přijímání potravy"],"answer":"tavení","hint":"Tavení je fyzikální proces u neživých látek."},
        {"id":"PR4-01-02-007","type":"choice","question":"Je oheň živý?","options":["ano, roste","ano, dýchá","ne, nemá buňky a nerozmnožuje se","ano, pohybuje se","ano, potřebuje vzduch"],"answer":"ne, nemá buňky a nerozmnožuje se","hint":"Oheň vypadá živě, ale nemá buňky."},
        {"id":"PR4-01-02-008","type":"choice","question":"Co potřebuje semínko, aby začalo klíčit?","options":["jen tmu","vodu, teplo a vzduch","jen kameny","jen sníh","jen vítr"],"answer":"vodu, teplo a vzduch","hint":"Klíčení = začátek růstu."},
        {"id":"PR4-01-02-009","type":"choice","question":"Které tvrzení je PRAVDIVÉ?","options":["všechny živé organismy umí létat","živé organismy nepotřebují vodu","živé organismy se rozmnožují","neživé věci rostou rychleji","kameny dýchají"],"answer":"živé organismy se rozmnožují","hint":"Rozmnožování = klíčový znak života."},
        {"id":"PR4-01-02-010","type":"choice","question":"Proč ryba patří do živé přírody?","options":["žije ve vodě","je mokrá","dýchá, roste a rozmnožuje se","je studená","plave"],"answer":"dýchá, roste a rozmnožuje se","hint":"Vlastnosti živého organismu."}
      ]
    },
    {
      "id": "PR4-01-03",
      "name": "Dělení živé přírody",
      "difficulty": 2,
      "theory": "Rostliny — fotosyntéza. Živočichové — aktivně hledají potravu. Houby — rozklad organické hmoty.",
      "tasks": [
        {"id":"PR4-01-03-001","type":"choice","question":"Čím se rostliny liší od živočichů?","options":["nemají barvu","vyrábí si potravu ze slunečního světla","nepotřebují vodu","nemají kořeny","jsou vždy malé"],"answer":"vyrábí si potravu ze slunečního světla","hint":"Fotosyntéza — jen rostliny to umí."},
        {"id":"PR4-01-03-002","type":"choice","question":"Proč houby nepatří mezi rostliny?","options":["jsou příliš malé","neumí fotosyntézu","jsou vždy jedovaté","rostou jen v lese","nemají barvu"],"answer":"neumí fotosyntézu","hint":"Houby si nevyrábí potravu ze slunce."},
        {"id":"PR4-01-03-003","type":"choice","question":"Co je fotosyntéza?","options":["způsob pohybu rostlin","výroba potravy ze slunečního světla","rozmnožování hub","dýchání živočichů","změna barvy listů"],"answer":"výroba potravy ze slunečního světla","hint":"Foto = světlo, syntéza = tvorba."},
        {"id":"PR4-01-03-004","type":"choice","question":"Co je společné všem živočichům?","options":["mají křídla","žijí ve vodě","aktivně přijímají potravu","mají srst","mají čtyři nohy"],"answer":"aktivně přijímají potravu","hint":"Živočichové musí hledat a jíst potravu."},
        {"id":"PR4-01-03-005","type":"choice","question":"Kam zařadíme mravence?","options":["rostliny","houby","nerosty","živočichové","neživá příroda"],"answer":"živočichové","hint":"Mravenec se pohybuje, hledá potravu."},
        {"id":"PR4-01-03-006","type":"choice","question":"Který organismus si NEDOKÁŽE vyrobit potravu ze slunce?","options":["dub","sedmikráska","mech","zajíc","kapradina"],"answer":"zajíc","hint":"Zajíc je živočich — musí jíst."},
        {"id":"PR4-01-03-007","type":"choice","question":"Kam patří plíseň?","options":["rostliny","živočichové","houby","nerosty","neživá příroda"],"answer":"houby","hint":"Plísně jsou druh hub."},
        {"id":"PR4-01-03-008","type":"choice","question":"Je mořská řasa rostlina?","options":["ne, je to houba","ne, je to živočich","ano, provádí fotosyntézu","ne, je neživá","ne, je to nerost"],"answer":"ano, provádí fotosyntézu","hint":"Řasy vyrábí potravu ze slunce."},
        {"id":"PR4-01-03-009","type":"choice","question":"Co mají společného kaktus a dub?","options":["oba kvetou v zimě","oba jsou rostliny","oba žijí v lese","oba jsou keře","oba mají jehličí"],"answer":"oba jsou rostliny","hint":"Různé, ale oboje rostliny."},
        {"id":"PR4-01-03-010","type":"choice","question":"Jak houby získávají živiny?","options":["fotosyntézou","lovem","rozkladem organické hmoty","z nerostů","ze vzduchu"],"answer":"rozkladem organické hmoty","hint":"Houby rozkládají zbytky rostlin a živočichů."}
      ]
    },
    {
      "id": "PR4-01-04",
      "name": "Neživá příroda podrobně",
      "difficulty": 2,
      "theory": "Voda (3 skupenství), vzduch (směs plynů), horniny a nerosty, půda, slunce (hvězda).",
      "tasks": [
        {"id":"PR4-01-04-001","type":"choice","question":"Jaká jsou tři skupenství vody?","options":["teplá, studená, vlažná","kapalná, pevná (led), plynná (pára)","slaná, sladká, minerální","čistá, špinavá, destilovaná","pitná, nepitná, teplá"],"answer":"kapalná, pevná (led), plynná (pára)","hint":"Tři formy existence vody."},
        {"id":"PR4-01-04-002","type":"choice","question":"Z čeho se skládá vzduch?","options":["jen z kyslíku","jen z dusíku","ze směsi plynů (hlavně dusík a kyslík)","jen z oxidu uhličitého","jen z vodní páry"],"answer":"ze směsi plynů (hlavně dusík a kyslík)","hint":"78 % dusík, 21 % kyslík."},
        {"id":"PR4-01-04-003","type":"choice","question":"Co je hornina?","options":["živý organismus","přírodní směs nerostů","druh rostliny","typ houby","kapalina"],"answer":"přírodní směs nerostů","hint":"Hornina = směs minerálů."},
        {"id":"PR4-01-04-004","type":"choice","question":"Co je Slunce?","options":["planeta","měsíc","hvězda","kometa","asteroid"],"answer":"hvězda","hint":"Slunce je naše nejbližší hvězda."},
        {"id":"PR4-01-04-005","type":"choice","question":"Jak vzniká půda?","options":["roste jako rostlina","zvětráváním hornin a rozkladem organismů","padá z oblak","lidé ji vyrábí","vzniká z vody"],"answer":"zvětráváním hornin a rozkladem organismů","hint":"Dlouhý proces — tisíce let."},
        {"id":"PR4-01-04-006","type":"choice","question":"Proč je Slunce důležité pro život?","options":["je hezké","dává teplo a světlo","je žluté","je velké","otáčí se"],"answer":"dává teplo a světlo","hint":"Bez slunce by nebyl život na Zemi."},
        {"id":"PR4-01-04-007","type":"choice","question":"Co se stane s vodou při 0 °C?","options":["vypaří se","zmrzne na led","nic","začne vřít","zmizí"],"answer":"zmrzne na led","hint":"Bod mrazu = 0 °C."},
        {"id":"PR4-01-04-008","type":"choice","question":"Co se stane s vodou při 100 °C?","options":["zmrzne","nic","začne vřít a vypařovat se","zhoustne","ztvrdne"],"answer":"začne vřít a vypařovat se","hint":"Bod varu = 100 °C."},
        {"id":"PR4-01-04-009","type":"choice","question":"Co je koloběh vody?","options":["voda jen teče do moře","výpar → mraky → déšť → řeky → moře","voda zmizí","voda se mění na kámen","voda stojí na místě"],"answer":"výpar → mraky → déšť → řeky → moře","hint":"Nekonečný cyklus vody v přírodě."},
        {"id":"PR4-01-04-010","type":"choice","question":"Který příklad je nerost?","options":["mech","houba","křemen","strom","ryba"],"answer":"křemen","hint":"Křemen je běžný minerál."}
      ]
    },
    {
      "id": "PR4-01-05",
      "name": "Živá vs neživá — mix",
      "difficulty": 3,
      "theory": "Procvičuj vše dohromady: rozlišování, vlastnosti, skupiny, neživá příroda.",
      "tasks": [
        {"id":"PR4-01-05-001","type":"choice","question":"Které DVĚ věci patří do neživé přírody?","options":["strom a ryba","mech a houba","voda a vzduch","kočka a pes","sedmikráska a mravenec"],"answer":"voda a vzduch","hint":"Oba nerostou, nerozmnožují se."},
        {"id":"PR4-01-05-002","type":"choice","question":"Proč diamant NENÍ živý?","options":["je tvrdý","je průhledný","nerozmnožuje se, neroste sám, nedýchá","je drahý","je malý"],"answer":"nerozmnožuje se, neroste sám, nedýchá","hint":"Nemá vlastnosti živého organismu."},
        {"id":"PR4-01-05-003","type":"choice","question":"Jakou roli mají houby v přírodě?","options":["vyrábí kyslík","rozkládají odumřelou hmotu","loví živočichy","tvoří horniny","vytvářejí vodu"],"answer":"rozkládají odumřelou hmotu","hint":"Houby jsou přírodní recyklátoři."},
        {"id":"PR4-01-05-004","type":"choice","question":"Co by se stalo bez rostlin?","options":["nic","nebyl by kyslík k dýchání","bylo by víc vody","bylo by tepleji","živočichové by fotosyntézovali"],"answer":"nebyl by kyslík k dýchání","hint":"Rostliny vyrábí kyslík fotosyntézou."},
        {"id":"PR4-01-05-005","type":"choice","question":"Která řada obsahuje POUZE živé organismy?","options":["strom, voda, mech","ryba, kámen, houba","mravenec, hřib, dub","vzduch, půda, led","slunce, oblak, vítr"],"answer":"mravenec, hřib, dub","hint":"Živočich + houba + rostlina = živé."},
        {"id":"PR4-01-05-006","type":"choice","question":"Kde najdeme živé organismy?","options":["jen na souši","jen ve vodě","jen ve vzduchu","v půdě, ve vodě, na souši i ve vzduchu","jen v lese"],"answer":"v půdě, ve vodě, na souši i ve vzduchu","hint":"Život je všude."},
        {"id":"PR4-01-05-007","type":"choice","question":"Je korál živý nebo neživý?","options":["neživý — je to kámen","živý — kolonie drobných živočichů","neživý — je ve vodě","živý — je to rostlina","neživý — nehýbe se"],"answer":"živý — kolonie drobných živočichů","hint":"Koráli jsou drobní mořští živočichové."},
        {"id":"PR4-01-05-008","type":"choice","question":"Co je přírodní společenstvo?","options":["jen rostliny","skupina lidí","soubor organismů na jednom místě","typ horniny","druh neživé přírody"],"answer":"soubor organismů na jednom místě","hint":"Les = stromy + zvířata + houby + půda."},
        {"id":"PR4-01-05-009","type":"choice","question":"Co mají společného houba a strom?","options":["oba dělají fotosyntézu","oba jsou živé organismy","oba jsou nerosty","oba mají květy","oba žijí ve vodě"],"answer":"oba jsou živé organismy","hint":"Oba rostou a rozmnožují se."},
        {"id":"PR4-01-05-010","type":"choice","question":"Proč chráníme přírodu?","options":["není to důležité","vše spolu souvisí a je propojené","jen kvůli rostlinám","jen kvůli zvířatům","jen kvůli lidem"],"answer":"vše spolu souvisí a je propojené","hint":"Živá i neživá příroda tvoří jeden celek."}
      ]
    }
  ]
}
